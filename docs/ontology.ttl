@prefix : <https://w3id.org/mqto#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://w3id.org/mqto#> .

<https://w3id.org/mqto> rdf:type owl:Ontology ;
                         owl:versionIRI <https://w3id.org/mqto/1.0> ;
                         owl:imports <http://rds.posccaesar.org/ontology/lis14/ont/ido-ssn/0.1> ;
                         <http://purl.org/dc/terms/abstract> "The Manufacturing Quality Troubleshooting Ontology (MQTO) provides a domain-independent semantic framework for modeling manufacturing quality inspection, failure diagnosis, and countermeasure recommendation. Building on the LIS (Lifecycle Information System) specified/actual pattern and integrating SOSA/SSN observation semantics, MQTO enables structured representation of Ishikawa (fishbone) root cause analysis across Machine, Material, and Method categories. The ontology supports both schema-level knowledge (failure types, metrics, countermeasure procedures) and instance-level data (actual observations, failure occurrences, executed remediation steps), making it applicable across diverse manufacturing domains including die-casting, injection molding, machining, and assembly processes."@en ;
                         <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0003-2661-5575> ;
                         <http://purl.org/dc/terms/created> "2026-03-17"^^xsd:date ;
                         <http://purl.org/dc/terms/creator> <https://orcid.org/0000-0001-9521-8907> ;
                         <http://purl.org/dc/terms/description> "A generalised ontology for manufacturing quality troubleshooting, abstracting from the die-casting domain. Covers both the specified (schema-level) and actual (instance-level) layers of a manufacturing process. This ontology generalizes the patterns established in the die-casting ontologies (dg.ttl and dga.ttl) to be applicable across different manufacturing domains, with a focus on root cause analysis, failure diagnosis, and countermeasure recommendation."@en ;
                         <http://purl.org/dc/terms/license> <http://www.apache.org/licenses/LICENSE-2.0> ;
                         <http://purl.org/dc/terms/publisher> <https://github.com/dg-assist> ;
                         <http://purl.org/dc/terms/rights> "Copyright 2026 DG Assist. Licensed under the Apache License, Version 2.0."@en ;
                         <http://purl.org/dc/terms/subject> "Industry 4.0"@en ,
                                                            "Ishikawa diagram"@en ,
                                                            "SOSA"@en ,
                                                            "SSN"@en ,
                                                            "die-casting"@en ,
                                                            "manufacturing"@en ,
                                                            "quality control"@en ,
                                                            "root cause analysis"@en ,
                                                            "troubleshooting"@en ;
                         <http://purl.org/dc/terms/title> "Manufacturing Quality Troubleshooting Ontology"@en ;
                         <http://purl.org/ontology/bibo/status> <http://purl.org/ontology/bibo/status/draft> ;
                         <http://purl.org/vocab/vann/preferredNamespacePrefix> "mqto" ;
                         <http://purl.org/vocab/vann/preferredNamespaceUri> "https://w3id.org/mqto#" ;
                         <http://schema.org/codeRepository> <https://github.com/dg-assist/mqto> ;
                         <http://schema.org/funding> <https://www.ffg.at/en/project/4641766> ;
                         <http://schema.org/logo> <https://dg-assist.github.io/mqto/logo.png> ;
                         rdfs:comment "Relationship to Procedural Knowledge Ontology (PKO): mqto countermeasure classes align with PKO procedure modeling patterns. mqto:Countermeasure is a subclass of pko:Procedure, representing remediation procedures in the specified layer. mqto:CountermeasureStep aligns with p-plan:Step for individual actions. In the actual layer, mqto:CountermeasureExecution extends pko:ProcedureExecution and mqto:CountermeasureStepExecution extends pko:StepExecution. Both ontologies follow a specification/execution (plan/actual) pattern, though mqto uses LIS (lis:Specified/lis:Actual with lis:implements) while PKO uses P-PLAN/PROV (with pko:executesProcedure/pko:executesStep). Key architectural difference: mqto externalizes step ordering via mqto:List containers for step reusability across procedures, while PKO embeds ordering directly in steps via pko:nextStep properties."@en ,
                                      "Relationship to die-casting ontologies: This ontology (mqto) is a domain-independent generalization of the die-casting quality inspection ontologies. The die-casting Base Model (dg.ttl, namespace https://w3id.org/dgassist#) represents the specified layer for die-casting with domain-specific classes such as Aggregate, Process, Material, and Product. The die-casting Actual Ontology (dga.ttl, namespace https://w3id.org/dgassist/actual#) extends this to the actual/instance layer with observation data and process executions. Both mqto and the die-casting ontologies build upon the LIS (Lifecycle Information System) upper ontology and integrate SOSA/SSN for observations."@en ;
                         rdfs:isDefinedBy <https://w3id.org/mqto/1.0> ;
                         rdfs:label "Manufacturing Quality Troubleshooting Ontology"@en ;
                         rdfs:seeAlso <http://purl.org/net/p-plan> ,
                                      <https://projekte.ffg.at/projekt/4641766> ,
                                      <https://w3id.org/dgassist> ,
                                      <https://w3id.org/dgassist/actual> ,
                                      <https://w3id.org/pko/1.0.0> ;
                         owl:versionInfo "1.0.0" ;
                         <http://xmlns.com/foaf/0.1/homepage> <https://dg-assist.github.io/mqto/> .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/abstract
<http://purl.org/dc/terms/abstract> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/created
<http://purl.org/dc/terms/created> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/subject
<http://purl.org/dc/terms/subject> rdf:type owl:AnnotationProperty .


###  http://purl.org/ontology/bibo/status
<http://purl.org/ontology/bibo/status> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
<http://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
<http://purl.org/vocab/vann/preferredNamespaceUri> rdf:type owl:AnnotationProperty .


###  http://schema.org/codeRepository
<http://schema.org/codeRepository> rdf:type owl:AnnotationProperty .


###  http://schema.org/funding
<http://schema.org/funding> rdf:type owl:AnnotationProperty .


###  http://schema.org/logo
<http://schema.org/logo> rdf:type owl:AnnotationProperty .


###  http://xmlns.com/foaf/0.1/homepage
<http://xmlns.com/foaf/0.1/homepage> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/mqto#appearedOn
:appearedOn rdf:type owl:ObjectProperty ;
            rdfs:domain :FailureOccurrence ;
            rdfs:range :ActualIshikawaItem ;
            rdfs:label "appeared on"@en .


###  https://w3id.org/mqto#baseFor
:baseFor rdf:type owl:ObjectProperty ;
         owl:inverseOf :basedOn ;
         rdfs:label "base for"@en .


###  https://w3id.org/mqto#basedOn
:basedOn rdf:type owl:ObjectProperty ;
         rdfs:domain :MetricAssessment ;
         rdfs:range :Observation ;
         rdfs:label "based on"@en .


###  https://w3id.org/mqto#calculatedFor
:calculatedFor rdf:type owl:ObjectProperty ;
               rdfs:domain :MetricAssessment ;
               rdfs:range :ActualIshikawaItem ;
               rdfs:label "calculated for"@en .


###  https://w3id.org/mqto#causedBy
:causedBy rdf:type owl:ObjectProperty ;
          owl:inverseOf :causes ;
          rdfs:domain :Failure ;
          rdfs:range :Failure ;
          rdfs:label "caused by"@en .


###  https://w3id.org/mqto#causedByModerately
:causedByModerately rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :causedBy ;
                    owl:inverseOf :causesModerately .


###  https://w3id.org/mqto#causedByStrongly
:causedByStrongly rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :causedBy ;
                  owl:inverseOf :causesStrongly .


###  https://w3id.org/mqto#causedByWeakly
:causedByWeakly rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf :causedBy ;
                owl:inverseOf :causesWeakly .


###  https://w3id.org/mqto#causes
:causes rdf:type owl:ObjectProperty ;
        rdfs:domain :Failure ;
        rdfs:range :Failure ;
        rdfs:label "causes"@en .


###  https://w3id.org/mqto#causesModerately
:causesModerately rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :causes .


###  https://w3id.org/mqto#causesStrongly
:causesStrongly rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf :causes .


###  https://w3id.org/mqto#causesWeakly
:causesWeakly rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :causes .


###  https://w3id.org/mqto#evaluatedBy
:evaluatedBy rdf:type owl:ObjectProperty ;
             rdfs:domain :ObservableProperty ;
             rdfs:range :MetricAssessment ;
             rdfs:comment "Relates an ObservableProperty to the MetricAssessment that evaluated it (actual layer). Inverse of mqto:evaluatesProperty. Counterpart to mqto:readBy in the specified layer."@en ;
             rdfs:label "evaluated by"@en .


###  https://w3id.org/mqto#evaluatesProperty
:evaluatesProperty rdf:type owl:ObjectProperty ;
                   owl:inverseOf :evaluatedBy ;
                   rdfs:domain :MetricAssessment ;
                   rdfs:range :ObservableProperty ;
                   rdfs:comment "Relates a MetricAssessment to the ObservableProperty it evaluated (actual layer). Counterpart to mqto:readsFrom, which relates a Metric to a Signal in the specified layer."@en ;
                   rdfs:label "evaluates property"@en .


###  https://w3id.org/mqto#failureBelongsTo
:failureBelongsTo rdf:type owl:ObjectProperty ;
                  owl:inverseOf :hasFailure ;
                  rdfs:domain :Failure ;
                  rdfs:range :IshikawaItem ;
                  rdfs:label "failure belongs to"@en .


###  https://w3id.org/mqto#first
:first rdf:type owl:ObjectProperty ;
       rdfs:domain :List ;
       rdfs:range :CountermeasureStep ;
       rdfs:comment "Points to the first CountermeasureStep in a reusable ordered list. The list structure (rather than a direct step-to-step chain) allows the same CountermeasureStep instance to appear in multiple Countermeasure procedures without embedding order into the step itself."@en .


###  https://w3id.org/mqto#hasFailure
:hasFailure rdf:type owl:ObjectProperty ;
            rdfs:domain :IshikawaItem ;
            rdfs:range :Failure ;
            rdfs:label "has failure"@en .


###  https://w3id.org/mqto#hasFirstStep
:hasFirstStep rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :hasStep ;
              rdfs:domain :CountermeasureExecution ;
              rdfs:range :CountermeasureStepExecution ;
              rdfs:comment "Points to the first CountermeasureStepExecution in the concrete execution chain. In the actual layer, steps are performed in a fixed linear order and are not reused, so the order is encoded directly in the chain via mqto:hasNextStep."@en ;
              rdfs:label "has first step"@en .


###  https://w3id.org/mqto#hasMetric
:hasMetric rdf:type owl:ObjectProperty ;
           owl:inverseOf :metricBelongsTo ;
           rdfs:domain :IshikawaItem ;
           rdfs:range :Metric ;
           rdfs:label "has metric"@en .


###  https://w3id.org/mqto#hasNextStep
:hasNextStep rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :hasStep ;
             rdfs:domain :CountermeasureStepExecution ;
             rdfs:range :CountermeasureStepExecution ;
             rdfs:comment "Links one CountermeasureStepExecution to the next in the concrete execution sequence. Unlike the specified layer (which uses mqto:List for reusability), the actual execution occurs once in a specific order, so step-to-step chaining is appropriate here."@en ;
             rdfs:label "has next step"@en .


###  https://w3id.org/mqto#hasStep
:hasStep rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf <http://rds.posccaesar.org/ontology/lis14/rdl/hasActivityPart> ;
         rdfs:domain :CountermeasureExecution ;
         rdfs:range :CountermeasureStepExecution ;
         rdfs:label "has step"@en .


###  https://w3id.org/mqto#metricBelongsTo
:metricBelongsTo rdf:type owl:ObjectProperty ;
                 rdfs:domain :Metric ;
                 rdfs:range :IshikawaItem ;
                 rdfs:label "metric belongs to"@en .


###  https://w3id.org/mqto#metricReferredBy
:metricReferredBy rdf:type owl:ObjectProperty ;
                  owl:inverseOf :refersToMetric ;
                  rdfs:domain :Metric ;
                  rdfs:range :Failure ;
                  rdfs:label "metric referred by"@en .


###  https://w3id.org/mqto#mitigated
:mitigated rdf:type owl:ObjectProperty ;
           rdfs:domain :CountermeasureExecution ;
           rdfs:range :FailureOccurrence ;
           rdfs:comment "A countermeasure execution mitigated a failure occurrence. Note: this is the actual-layer forward property (past participle). The specified-layer equivalent uses mqto:mitigates (active voice). The naming difference is intentional: 'mitigated' records a completed fact at instance level, while 'mitigates' expresses a general capability at schema level."@en ;
           rdfs:label "mitigated"@en .


###  https://w3id.org/mqto#mitigatedBy
:mitigatedBy rdf:type owl:ObjectProperty ;
             rdfs:domain :Failure ;
             rdfs:range :Countermeasure ;
             rdfs:label "mitigated by"@en .


###  https://w3id.org/mqto#mitigates
:mitigates rdf:type owl:ObjectProperty ;
           owl:inverseOf :mitigatedBy ;
           rdfs:domain :Countermeasure ;
           rdfs:range :Failure ;
           rdfs:label "mitigates"@en .


###  https://w3id.org/mqto#providesSignal
:providesSignal rdf:type owl:ObjectProperty ;
                owl:inverseOf :signalProvidedBy ;
                rdfs:domain :IshikawaItem ;
                rdfs:range :Signal ;
                rdfs:comment "Relates an IshikawaItem (Machine, Material, or Method) to the data channels (Signals) associated with it. A Signal may be an output channel carrying measurement data from the item (e.g. a temperature sensor reading) or an input channel carrying control data to the item (e.g. a setpoint or actuator command). The Signal is a specified channel descriptor; actual observations are made via sosa:Observation on the corresponding ActualIshikawaItem."@en ;
                rdfs:label "provides signal"@en .


###  https://w3id.org/mqto#raised
:raised rdf:type owl:ObjectProperty ;
        owl:inverseOf :raisedBy ;
        rdfs:domain :MetricAssessment ;
        rdfs:range :FailureOccurrence ;
        rdfs:label "raised"@en .


###  https://w3id.org/mqto#raisedBy
:raisedBy rdf:type owl:ObjectProperty ;
          rdfs:domain :FailureOccurrence ;
          rdfs:range :MetricAssessment ;
          rdfs:label "raised by"@en .


###  https://w3id.org/mqto#readBy
:readBy rdf:type owl:ObjectProperty ;
        rdfs:domain :Signal ;
        rdfs:range :Metric ;
        rdfs:comment "Relates a Signal (data channel) to the Metric that is computed from it (specified layer). Inverse of mqto:readsFrom. For the actual-layer counterpart see mqto:evaluatedBy."@en ;
        rdfs:label "read by"@en .


###  https://w3id.org/mqto#readsFrom
:readsFrom rdf:type owl:ObjectProperty ;
           owl:inverseOf :readBy ;
           rdfs:domain :Metric ;
           rdfs:range :Signal ;
           rdfs:comment "Relates a Metric to the Signal (data channel) it is computed from (specified layer). Inverse of mqto:readBy. For the actual-layer counterpart see mqto:evaluatesProperty."@en ;
           rdfs:label "reads from"@en .


###  https://w3id.org/mqto#refersToMetric
:refersToMetric rdf:type owl:ObjectProperty ;
                rdfs:domain :Failure ;
                rdfs:range :Metric ;
                rdfs:label "refers to metric"@en .


###  https://w3id.org/mqto#rest
:rest rdf:type owl:ObjectProperty ;
      rdfs:domain :List ;
      rdfs:range :List ;
      rdfs:comment "Points to the remainder of the ordered step list. Together with mqto:first, this implements a reusable linked-list container so that step order is encoded in the list, not in the steps themselves. The list must terminate at mqto:nil; circular references are not permitted, though OWL cannot formally enforce acyclicity."@en .


###  https://w3id.org/mqto#resultProperty
:resultProperty rdf:type owl:ObjectProperty ;
                rdfs:domain :Metric ;
                rdfs:range rdf:Property ;
                rdfs:comment "Meta-property that specifies which data property of sosa:Result instances should be extracted and used as input for this Metric's calculation. For example, if a Metric's resultProperty points to dga:measValue, the metric calculation will extract the measValue field from each Result instance within the specified time window. If it points to dga:diameter, it extracts the diameter values instead. This enables multiple metrics to derive different calculations from the same observation results by selecting different result attributes. Note: This is a meta-level construct (an object property pointing to data properties), which while not ideal OWL modeling practice, provides a simple declarative mechanism for metrics to specify their input data field without requiring complex extraction rules or SPARQL property paths."@en ;
                rdfs:label "result property"@en .


###  https://w3id.org/mqto#signalProvidedBy
:signalProvidedBy rdf:type owl:ObjectProperty ;
                  rdfs:domain :Signal ;
                  rdfs:range :IshikawaItem ;
                  rdfs:label "signal provided by"@en .


###  https://w3id.org/mqto#steps
:steps rdf:type owl:ObjectProperty ;
       rdfs:domain :Countermeasure ;
       rdfs:range :List ;
       rdfs:comment "Links a Countermeasure to its ordered list of steps. The indirection via mqto:List enables the same CountermeasureStep to be referenced in multiple Countermeasure definitions (reuse across procedures)."@en ;
       rdfs:label "steps"@en .


###  https://w3id.org/mqto#suggested
:suggested rdf:type owl:ObjectProperty ;
           owl:inverseOf :suggestedBy ;
           rdfs:domain :FailureOccurrence ;
           rdfs:range :CountermeasureExecution ;
           rdfs:comment "A failure occurrence suggested a countermeasure execution."@en ;
           rdfs:label "suggested"@en .


###  https://w3id.org/mqto#suggestedBy
:suggestedBy rdf:type owl:ObjectProperty ;
             rdfs:domain :CountermeasureExecution ;
             rdfs:range :FailureOccurrence ;
             rdfs:comment "A countermeasure execution was suggested by a failure occurrence."@en ;
             rdfs:label "suggested by"@en .


#################################################################
#    Data properties
#################################################################

###  http://purl.org/dc/terms/identifier
<http://purl.org/dc/terms/identifier> rdf:type owl:DatatypeProperty .


###  https://w3id.org/mqto#abortedReason
:abortedReason rdf:type owl:DatatypeProperty ;
               rdfs:range xsd:string ;
               rdfs:label "aborted reason"@en .


###  https://w3id.org/mqto#abortedTime
:abortedTime rdf:type owl:DatatypeProperty ;
             rdfs:range xsd:dateTime ;
             rdfs:label "aborted time"@en .


###  https://w3id.org/mqto#assessmentValue
:assessmentValue rdf:type owl:DatatypeProperty ;
                 rdfs:domain :MetricAssessment ;
                 rdfs:range xsd:boolean ;
                 rdfs:comment "Boolean pass/fail decision resulting from comparing the calculatedValue against the Metric's threshold bounds (lowerBound/upperBound). True indicates a threshold violation (failure condition detected), false indicates normal operation within bounds."@en ;
                 rdfs:label "assessment value"@en .


###  https://w3id.org/mqto#calculatedTime
:calculatedTime rdf:type owl:DatatypeProperty ;
                rdfs:domain :MetricAssessment ;
                rdfs:range xsd:dateTime ;
                rdfs:label "calculated time"@en .


###  https://w3id.org/mqto#calculatedValue
:calculatedValue rdf:type owl:DatatypeProperty ;
                 rdfs:domain :MetricAssessment ;
                 rdfs:range xsd:double ;
                 rdfs:comment "The actual computed numeric value of the metric assessment. This preserves the quantitative result before threshold comparison, enabling trend analysis, statistical modeling, and root cause correlation. For example, if a temperature metric calculates 85.7°C and the upperBound is 80°C, calculatedValue is 85.7 while assessmentValue would be true (indicating a violation). The unit of measurement is inherited from the implemented Metric specification."@en ;
                 rdfs:label "calculated value"@en .


###  https://w3id.org/mqto#completionTime
:completionTime rdf:type owl:DatatypeProperty ;
                rdfs:domain :CountermeasureStepExecution ;
                rdfs:range xsd:dateTime ;
                rdfs:label "completion time"@en .


###  https://w3id.org/mqto#endTime
:endTime rdf:type owl:DatatypeProperty ;
         rdfs:range xsd:dateTime ;
         rdfs:label "end time"@en .


###  https://w3id.org/mqto#identifier
:identifier rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf <http://purl.org/dc/terms/identifier> ;
            rdfs:label "identifier"@en .


###  https://w3id.org/mqto#lowerBound
:lowerBound rdf:type owl:DatatypeProperty ;
            rdfs:domain :Metric ;
            rdfs:range rdfs:Literal ;
            rdfs:label "lower bound"@en .


###  https://w3id.org/mqto#markdownContent
:markdownContent rdf:type owl:DatatypeProperty ;
                 rdfs:domain [ rdf:type owl:Class ;
                               owl:unionOf ( :Countermeasure
                                             :CountermeasureStep
                                           )
                             ] ;
                 rdfs:range xsd:string ;
                 rdfs:label "markdown content"@en .


###  https://w3id.org/mqto#measValue
:measValue rdf:type owl:DatatypeProperty ;
           rdfs:domain :Result ;
           rdfs:range xsd:float ;
           rdfs:label "measurement value"@en .


###  https://w3id.org/mqto#method
:method rdf:type owl:DatatypeProperty ;
        rdfs:domain :Metric ;
        rdfs:label "method"@en .


###  https://w3id.org/mqto#reasoningLine
:reasoningLine rdf:type owl:DatatypeProperty ;
               rdfs:domain :CountermeasureExecution ;
               rdfs:range xsd:string ;
               rdfs:label "reasoning line"@en .


###  https://w3id.org/mqto#role
:role rdf:type owl:DatatypeProperty ;
      rdfs:domain :CountermeasureStep ;
      rdfs:range xsd:string ;
      rdfs:label "role"@en .


###  https://w3id.org/mqto#score
:score rdf:type owl:DatatypeProperty ;
       rdfs:domain :CountermeasureExecution ;
       rdfs:range xsd:double ;
       rdfs:label "score"@en .


###  https://w3id.org/mqto#startTime
:startTime rdf:type owl:DatatypeProperty ;
           rdfs:range xsd:dateTime ;
           rdfs:label "start time"@en .


###  https://w3id.org/mqto#timeWindowSize
:timeWindowSize rdf:type owl:DatatypeProperty ;
                rdfs:domain :Metric ;
                rdfs:range rdfs:Literal ;
                rdfs:label "time window size"@en .


###  https://w3id.org/mqto#upperBound
:upperBound rdf:type owl:DatatypeProperty ;
            rdfs:domain :Metric ;
            rdfs:range rdfs:Literal ;
            rdfs:label "upper bound"@en .


###  https://w3id.org/mqto#viewTime
:viewTime rdf:type owl:DatatypeProperty ;
          rdfs:domain :FailureOccurrence ;
          rdfs:range xsd:dateTime ;
          rdfs:label "view time"@en .


###  https://w3id.org/mqto#weight
:weight rdf:type owl:DatatypeProperty ;
        rdfs:domain [ rdf:type owl:Class ;
                      owl:unionOf ( :Countermeasure
                                    :Failure
                                  )
                    ] ;
        rdfs:range xsd:int ;
        rdfs:label "weight"@en .


#################################################################
#    Classes
#################################################################

###  http://purl.org/net/p-plan#Step
<http://purl.org/net/p-plan#Step> rdf:type owl:Class .


###  http://www.w3.org/1999/02/22-rdf-syntax-ns#Property
rdf:Property rdf:type owl:Class .


###  http://www.w3.org/ns/sosa/ActuableProperty
<http://www.w3.org/ns/sosa/ActuableProperty> rdf:type owl:Class .


###  http://xmlns.com/foaf/0.1/Person
<http://xmlns.com/foaf/0.1/Person> rdf:type owl:Class .


###  https://w3id.org/mqto#ActuableProperty
:ActuableProperty rdf:type owl:Class ;
                  rdfs:subClassOf <http://www.w3.org/ns/sosa/ActuableProperty> ,
                                  :Property ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://www.w3.org/ns/ssn/isPropertyOf> ;
                                    owl:allValuesFrom :ActualIshikawaItem
                                  ] ;
                  rdfs:comment "An actuable property of an ActualIshikawaItem that can be controlled or modified via Actuations. As a subclass of mqto:Property, it implements a Signal specification from the specified layer. Represents properties that can be set or modified, such as setpoints, valve positions, motor speeds, or control commands. The Signal in the specified layer defines the control channel metadata, while ActuableProperty represents the actual controllable quality of a specific feature of interest."@en ;
                  rdfs:label "Actuable Property"@en .


###  https://w3id.org/mqto#ActualIshikawaItem
:ActualIshikawaItem rdf:type owl:Class ;
                    rdfs:subClassOf <http://rds.posccaesar.org/ontology/lis14/rdl/Actual> ,
                                    <http://www.w3.org/ns/sosa/FeatureOfInterest> ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty <http://www.w3.org/ns/sosa/isFeatureOfInterestOf> ;
                                      owl:allValuesFrom :Observation
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty <http://www.w3.org/ns/ssn/hasProperty> ;
                                      owl:allValuesFrom :ObservableProperty
                                    ] ;
                    rdfs:comment "Abstract superclass for actual/instance layer counterparts of IshikawaItem. Integrates SOSA: each ActualIshikawaItem is a FeatureOfInterest that can be observed, has ObservableProperties, and can have FailureOccurrences. In die-casting (dga ontology), concrete instances include specific die-casting cells, material batches, and production runs."@en ;
                    rdfs:label "Actual Ishikawa Item"@en .


###  https://w3id.org/mqto#Countermeasure
:Countermeasure rdf:type owl:Class ;
                rdfs:subClassOf <http://rds.posccaesar.org/ontology/lis14/rdl/Activity> ,
                                <http://rds.posccaesar.org/ontology/lis14/rdl/Specified> ,
                                <https://w3id.org/pko#Procedure> ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :steps ;
                                  owl:someValuesFrom :List
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <http://rds.posccaesar.org/ontology/lis14/rdl/hasParticipant> ;
                                  owl:allValuesFrom [ rdf:type owl:Class ;
                                                      owl:unionOf ( :Machine
                                                                    :Material
                                                                  )
                                                    ]
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :mitigates ;
                                  owl:allValuesFrom :Failure
                                ] ;
                rdfs:comment "A remediation procedure that mitigates one or more Failures. Countermeasures are structured as ordered sequences of CountermeasureSteps, represented via the mqto:List pattern for reusability. As a subclass of pko:Procedure, countermeasures align with the Procedural Knowledge Ontology's procedure modeling patterns while maintaining integration with the LIS specified/actual architecture."@en ;
                rdfs:label "Countermeasure"@en .


###  https://w3id.org/mqto#CountermeasureExecution
:CountermeasureExecution rdf:type owl:Class ;
                         rdfs:subClassOf <http://rds.posccaesar.org/ontology/lis14/rdl/Actual> ,
                                         <https://w3id.org/pko#ProcedureExecution> ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty <http://rds.posccaesar.org/ontology/lis14/rdl/implements> ;
                                           owl:someValuesFrom :Countermeasure
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty <http://rds.posccaesar.org/ontology/lis14/rdl/hasParticipant> ;
                                           owl:allValuesFrom [ rdf:type owl:Class ;
                                                               owl:unionOf ( :MaterialChunk
                                                                             :PhysicalMachine
                                                                           )
                                                             ]
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty :hasStep ;
                                           owl:allValuesFrom :CountermeasureStepExecution
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty :mitigated ;
                                           owl:allValuesFrom :FailureOccurrence
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty :suggestedBy ;
                                           owl:allValuesFrom :FailureOccurrence
                                         ] ;
                         rdfs:comment "The actual execution of a Countermeasure procedure, performed to mitigate one or more FailureOccurrences. Links to the Countermeasure specification via lis:implements (LIS pattern) and tracks which specific failures were addressed. As a subclass of pko:ProcedureExecution, countermeasure executions align with PKO's procedure execution model while maintaining LIS actual/specified semantics. Note: Does not directly subclass lis:Activity (which is lis:Specified), but implements Countermeasure (which is lis:Activity), maintaining the LIS distinction between specified and actual layers."@en ;
                         rdfs:label "Countermeasure Execution"@en .


###  https://w3id.org/mqto#CountermeasureStep
:CountermeasureStep rdf:type owl:Class ;
                    rdfs:subClassOf <http://purl.org/net/p-plan#Step> ,
                                    <http://rds.posccaesar.org/ontology/lis14/rdl/Activity> ,
                                    <http://rds.posccaesar.org/ontology/lis14/rdl/Specified> ;
                    rdfs:comment "A reusable specification of a single step within a Countermeasure procedure. Because the same step (e.g. 'clean the mould') may occur in multiple Countermeasures, ordering is not encoded in the step itself but in the mqto:List that references it. As a subclass of p-plan:Step, countermeasure steps align with the P-PLAN ontology for plan-based activity modeling."@en ;
                    rdfs:label "Countermeasure Step"@en .


###  https://w3id.org/mqto#CountermeasureStepExecution
:CountermeasureStepExecution rdf:type owl:Class ;
                             rdfs:subClassOf <http://rds.posccaesar.org/ontology/lis14/rdl/Actual> ,
                                             <https://w3id.org/pko#StepExecution> ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty <http://rds.posccaesar.org/ontology/lis14/rdl/implements> ;
                                               owl:someValuesFrom :CountermeasureStep
                                             ] ;
                             rdfs:comment "The actual, single execution of one CountermeasureStep. Each execution implements a specific CountermeasureStep from the specified layer via lis:implements, performed in a concrete, non-reused linear order encoded via mqto:hasFirstStep / mqto:hasNextStep, contrasting with the specified layer where mqto:List enables step reuse across procedures. As a subclass of pko:StepExecution, countermeasure step executions align with PKO's step execution model. Note: Does not directly subclass lis:Activity (which is lis:Specified), but implements CountermeasureStep (which is lis:Activity), maintaining the LIS distinction between specified and actual layers."@en ;
                             rdfs:label "Countermeasure Step Execution"@en .


###  https://w3id.org/mqto#Failure
:Failure rdf:type owl:Class ;
         rdfs:subClassOf <http://rds.posccaesar.org/ontology/lis14/rdl/Specified> ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :failureBelongsTo ;
                           owl:someValuesFrom :IshikawaItem
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :causedBy ;
                           owl:allValuesFrom :Failure
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :causes ;
                           owl:allValuesFrom :Failure
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :failureBelongsTo ;
                           owl:allValuesFrom :IshikawaItem
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :mitigatedBy ;
                           owl:allValuesFrom :Countermeasure
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :refersToMetric ;
                           owl:allValuesFrom :Metric
                         ] ;
         rdfs:label "Failure"@en .


###  https://w3id.org/mqto#FailureOccurrence
:FailureOccurrence rdf:type owl:Class ;
                   rdfs:subClassOf <http://rds.posccaesar.org/ontology/lis14/rdl/Actual> ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty <http://rds.posccaesar.org/ontology/lis14/rdl/implements> ;
                                     owl:someValuesFrom :Failure
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :appearedOn ;
                                     owl:someValuesFrom :ActualIshikawaItem
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :mitigatedBy ;
                                     owl:allValuesFrom :CountermeasureExecution
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :raisedBy ;
                                     owl:allValuesFrom :MetricAssessment
                                   ] ;
                   rdfs:label "Failure Occurrence"@en .


###  https://w3id.org/mqto#IshikawaItem
:IshikawaItem rdf:type owl:Class ;
              rdfs:subClassOf <http://rds.posccaesar.org/ontology/lis14/rdl/Specified> ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :hasFailure ;
                                owl:allValuesFrom :Failure
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :hasMetric ;
                                owl:allValuesFrom :Metric
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :providesSignal ;
                                owl:allValuesFrom :Signal
                              ] ;
              rdfs:comment "Abstract superclass for the three categories of root causes in an Ishikawa (fishbone) diagram: Machine, Material, and Method. In die-casting ontologies (dg.ttl), this pattern is instantiated with dg:Aggregate (equivalent to Machine), dg:Material, and dg:Process (equivalent to Method), plus dg:Product (output of manufacturing, no direct mqto equivalent)."@en ;
              rdfs:label "Ishikawa Item"@en .


###  https://w3id.org/mqto#List
:List rdf:type owl:Class ;
      rdfs:comment "An ordered, reusable container of CountermeasureSteps within the specified layer. Modelled as a linked list (mqto:first / mqto:rest) so that step order is external to the step instances, allowing steps to be shared across different Countermeasure procedures. The list is terminated by mqto:nil."@en ;
      rdfs:label "List"@en .


###  https://w3id.org/mqto#Machine
:Machine rdf:type owl:Class ;
         rdfs:subClassOf <http://rds.posccaesar.org/ontology/lis14/rdl/PhysicalArtefact> ,
                         :IshikawaItem ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty <http://rds.posccaesar.org/ontology/lis14/rdl/participantIn> ;
                           owl:allValuesFrom :Method
                         ] ;
         rdfs:comment "Manufacturing equipment, tools, and devices (the 'M' in Ishikawa's Machine). Represents specified physical resources that participate in Methods. In die-casting, dg:Aggregate represents machines like die-casting cells, furnaces, and robots. Machines provide Signals (sensor readings, control channels) and can have associated Failures and Metrics."@en ;
         rdfs:label "Machine"@en .


###  https://w3id.org/mqto#Material
:Material rdf:type owl:Class ;
          rdfs:subClassOf <http://rds.posccaesar.org/ontology/lis14/rdl/Compound> ,
                          <http://rds.posccaesar.org/ontology/lis14/rdl/PhysicalArtefact> ,
                          :IshikawaItem ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty <http://rds.posccaesar.org/ontology/lis14/rdl/participantIn> ;
                            owl:allValuesFrom :Method
                          ] ;
          rdfs:comment "Raw materials, consumables, and inputs to manufacturing (the 'M' in Ishikawa's Material). Represents specified material types that participate in Methods. In die-casting (dg:Material), this includes aluminum alloys, die lubricants, release agents, and other consumables. Materials can have properties monitored via Signals and associated quality Metrics."@en ;
          rdfs:label "Material"@en .


###  https://w3id.org/mqto#MaterialChunk
:MaterialChunk rdf:type owl:Class ;
               rdfs:subClassOf <http://rds.posccaesar.org/ontology/lis14/rdl/Compound> ,
                               <http://rds.posccaesar.org/ontology/lis14/rdl/PhysicalArtefact> ,
                               :ActualIshikawaItem ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty <http://rds.posccaesar.org/ontology/lis14/rdl/participantIn> ;
                                 owl:allValuesFrom :ProcessExecution
                               ] ;
               rdfs:comment "Actual material instance, the instance-layer counterpart of Material. Represents specific batches, lots, or quantities of material with identifiers, composition data, and quality measurements. In die-casting (dga ontology), examples include specific aluminum alloy batches with batch numbers, chemical composition, and temperature observations."@en ;
               rdfs:label "Material Chunk"@en .


###  https://w3id.org/mqto#Method
:Method rdf:type owl:Class ;
        rdfs:subClassOf <http://rds.posccaesar.org/ontology/lis14/rdl/Activity> ,
                        :IshikawaItem ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty <http://rds.posccaesar.org/ontology/lis14/rdl/activityPartOf> ;
                          owl:allValuesFrom :Method
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty <http://rds.posccaesar.org/ontology/lis14/rdl/hasActivityPart> ;
                          owl:allValuesFrom :Method
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty <http://rds.posccaesar.org/ontology/lis14/rdl/hasParticipant> ;
                          owl:allValuesFrom [ rdf:type owl:Class ;
                                              owl:unionOf ( :Machine
                                                            :Material
                                                          )
                                            ]
                        ] ;
        rdfs:comment "A manufacturing process or procedure (the 'M' in Ishikawa's Method). Represents the specified activities and steps in manufacturing. In die-casting (dg:Process), this includes operations like melting, injection, cooling, and demolding. Methods can be decomposed into sub-methods and have Machines and Materials as participants."@en ;
        rdfs:label "Method"@en .


###  https://w3id.org/mqto#Metric
:Metric rdf:type owl:Class ;
        rdfs:subClassOf <http://rds.posccaesar.org/ontology/lis14/rdl/Specified> ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :metricBelongsTo ;
                          owl:allValuesFrom :IshikawaItem
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :metricReferredBy ;
                          owl:allValuesFrom :Failure
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :readsFrom ;
                          owl:allValuesFrom :Signal
                        ] ;
        rdfs:label "Metric"@en .


###  https://w3id.org/mqto#MetricAssessment
:MetricAssessment rdf:type owl:Class ;
                  rdfs:subClassOf <http://rds.posccaesar.org/ontology/lis14/rdl/Actual> ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://rds.posccaesar.org/ontology/lis14/rdl/implements> ;
                                    owl:someValuesFrom :Metric
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :calculatedFor ;
                                    owl:someValuesFrom :ActualIshikawaItem
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :basedOn ;
                                    owl:allValuesFrom :Observation
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :evaluatesProperty ;
                                    owl:allValuesFrom :ObservableProperty
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :raised ;
                                    owl:allValuesFrom :FailureOccurrence
                                  ] ;
                  rdfs:label "Metric Assessment"@en .


###  https://w3id.org/mqto#ObservableProperty
:ObservableProperty rdf:type owl:Class ;
                    rdfs:subClassOf <http://www.w3.org/ns/sosa/ObservableProperty> ,
                                    :Property ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty <http://www.w3.org/ns/ssn/isPropertyOf> ;
                                      owl:allValuesFrom :ActualIshikawaItem
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :evaluatedBy ;
                                      owl:allValuesFrom :MetricAssessment
                                    ] ;
                    rdfs:comment "An observable property of an ActualIshikawaItem that can be measured via Observations. As a subclass of mqto:Property, it implements a Signal specification from the specified layer, establishing traceability from actual observations back to the specified data channel definition. Note: subclassing both sosa:ObservableProperty (an abstract quality type) and lis:Actual (via mqto:Property, a concrete instance) reflects the modelling choice that each mqto:ObservableProperty individual represents a specific, concrete observable quality tied to a particular actual item — not a reusable abstract type. This parallels how sosa:ObservableProperty instances are used in practice (e.g. 'the temperature of this specific machine part') rather than as universal property types."@en ;
                    rdfs:label "Observable Property"@en .


###  https://w3id.org/mqto#Observation
:Observation rdf:type owl:Class ;
             rdfs:subClassOf <http://www.w3.org/ns/sosa/Observation> ;
             rdfs:comment "Subclass of sosa:Observation, representing a single sensor reading or measurement event. Links to an ActualIshikawaItem (feature of interest), an ObservableProperty (what is being measured), and a Result (the measured value). In die-casting (dga ontology), observations capture time-series data from PLCs, sensors, and SCADA systems - e.g., furnace temperature readings, die pressure measurements, cycle times."@en ;
             rdfs:label "Observation"@en .


###  https://w3id.org/mqto#PhysicalMachine
:PhysicalMachine rdf:type owl:Class ;
                 rdfs:subClassOf <http://rds.posccaesar.org/ontology/lis14/rdl/PhysicalArtefact> ,
                                 :ActualIshikawaItem ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty <http://rds.posccaesar.org/ontology/lis14/rdl/participantIn> ;
                                   owl:allValuesFrom :ProcessExecution
                                 ] ;
                 rdfs:comment "Actual machine instance, the instance-layer counterpart of Machine. Represents specific physical equipment with serial numbers, operational history, and sensor data. In die-casting (dga ontology), examples include specific die-casting cells (e.g., 'Cell_TCG_200'), furnaces, and robots with concrete observation data."@en ;
                 rdfs:label "Physical Machine"@en .


###  https://w3id.org/mqto#ProcessExecution
:ProcessExecution rdf:type owl:Class ;
                  rdfs:subClassOf :ActualIshikawaItem ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://rds.posccaesar.org/ontology/lis14/rdl/implements> ;
                                    owl:someValuesFrom :Method
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://rds.posccaesar.org/ontology/lis14/rdl/hasParticipant> ;
                                    owl:allValuesFrom [ rdf:type owl:Class ;
                                                        owl:unionOf ( :MaterialChunk
                                                                      :PhysicalMachine
                                                                    )
                                                      ]
                                  ] ;
                  rdfs:comment "Actual execution of a Method, the instance-layer counterpart of Method. Links to concrete PhysicalMachines and MaterialChunks as participants. In die-casting (dga ontology), this represents actual production shots with specific machines, material batches, timestamps, and observation data. Note: ProcessExecution does not directly subclass lis:Activity (which is lis:Specified), but instead subclasses ActualIshikawaItem (lis:Actual) and implements Method (which is lis:Activity). This maintains the LIS distinction between specified and actual layers."@en ;
                  rdfs:label "Process Execution"@en .


###  https://w3id.org/mqto#Property
:Property rdf:type owl:Class ;
          rdfs:subClassOf <http://rds.posccaesar.org/ontology/lis14/rdl/Actual> ,
                          <http://www.w3.org/ns/ssn/Property> ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty <http://rds.posccaesar.org/ontology/lis14/rdl/implements> ;
                            owl:someValuesFrom :Signal
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty <http://www.w3.org/ns/ssn/isPropertyOf> ;
                            owl:allValuesFrom :ActualIshikawaItem
                          ] ;
          rdfs:comment "Actual-layer counterpart of Signal. Represents a property (observable or actuable) of an ActualIshikawaItem that implements a Signal specification from the specified layer. While Signal defines the data channel metadata (identifier, unit, sampling rate, direction), Property represents the actual measured or actuated quality of a specific feature of interest. This class serves as the abstract superclass for both ObservableProperty (for sensing/measurement) and ActuableProperty (for actuation/control)."@en ;
          rdfs:label "Property"@en .


###  https://w3id.org/mqto#Result
:Result rdf:type owl:Class ;
        rdfs:subClassOf <http://www.w3.org/ns/sosa/Result> ;
        rdfs:label "Result"@en .


###  https://w3id.org/mqto#Signal
:Signal rdf:type owl:Class ;
        rdfs:subClassOf <http://rds.posccaesar.org/ontology/lis14/rdl/Specified> ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :readBy ;
                          owl:allValuesFrom :Metric
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :signalProvidedBy ;
                          owl:allValuesFrom :IshikawaItem
                        ] ;
        rdfs:comment "A specified data channel in the electrical-engineering sense: a named, typed signal such as a PLC variable, an analog voltage line, a fieldbus message, or a time-series data stream. A Signal may carry measurement data (sensor/output signals), control data (actuator/input signals), or both simultaneously — a setpoint, for instance, is written as a command to an actuator and can equally be read back as an observable value. It describes the metadata of the channel (identifier, unit, sampling rate, direction, etc.) rather than any particular observation or sensor device. It sits in the specified layer as the concrete data-source or data-sink binding for an abstract Metric, and is thereby distinct from sosa:ObservableProperty (which characterises an observable quality of a feature of interest in the actual layer) and from sosa:Sensor (which is the physical observing device)."@en ;
        rdfs:label "Signal"@en .


