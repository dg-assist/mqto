@prefix : <https://w3id.org/mqto#> .
@prefix lis: <http://rds.posccaesar.org/ontology/lis14/rdl/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pko: <https://w3id.org/pko#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix ssn: <http://www.w3.org/ns/ssn/> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix mqto: <https://w3id.org/mqto#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix p-plan: <http://purl.org/net/p-plan#> .
@prefix schema: <http://schema.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <https://w3id.org/mqto#> .

<https://w3id.org/mqto> rdf:type owl:Ontology ;
                         owl:versionIRI <https://w3id.org/mqto/1.0> ;
                         owl:imports <http://rds.posccaesar.org/ontology/lis14/ont/ido-ssn/0.1> ,
                                     <https://w3id.org/pko/1.0.0> ;
                         dcterms:abstract "The Manufacturing Quality Troubleshooting Ontology (MQTO) provides a domain-independent semantic framework for modeling manufacturing quality inspection, failure diagnosis, and countermeasure recommendation. Building on the LIS (Lifecycle Information System) specified/actual pattern and integrating SOSA/SSN observation semantics, MQTO enables structured representation of Ishikawa (fishbone) root cause analysis across five categories: Machine, Manpower, Material, Measurement, and Method. The ontology supports both schema-level knowledge (failure types, metrics, countermeasure procedures) and instance-level data (actual observations, failure occurrences, executed remediation steps), making it applicable across diverse manufacturing domains including die-casting, injection molding, machining, and assembly processes."@en ;
                         dcterms:contributor <https://orcid.org/0000-0002-3050-159X> ,
                                             <https://orcid.org/0000-0003-2661-5575> ,
                                             <https://orcid.org/0000-0003-3445-0504> ;
                         dcterms:created "2026-03-17"^^xsd:date ;
                         dcterms:modified "2026-04-14"^^xsd:date ;
                         dcterms:license <http://www.apache.org/licenses/LICENSE-2.0> ;
                         dcterms:publisher <https://github.com/dg-assist> ;
                         dcterms:rights "Copyright 2026 DG Assist. Licensed under the Apache License, Version 2.0."@en ;
                         dcterms:subject "Industry 4.0"@en ,
                                         "Ishikawa diagram"@en ,
                                         "SOSA"@en ,
                                         "SSN"@en ,
                                         "manufacturing"@en ,
                                         "quality control"@en ,
                                         "root cause analysis"@en ,
                                         "troubleshooting"@en ;
                         dcterms:title "Manufacturing Quality Troubleshooting Ontology"@en ;
                         bibo:doi "10.5281/zenodo.19571023" ;
                         bibo:status <http://purl.org/ontology/bibo/status/draft> ;
                         vann:preferredNamespacePrefix "mqto" ;
                         vann:preferredNamespaceUri "https://w3id.org/mqto#" ;
                         schema:codeRepository <https://github.com/dg-assist/mqto> ;
                         schema:funding <https://projekte.ffg.at/projekt/4641766> ;
                         schema:logo <https://dg-assist.github.io/mqto/logo.png> ;
                         rdfs:comment "Relationship to Procedural Knowledge Ontology (PKO): mqto countermeasure classes align with PKO procedure modeling patterns. mqto:Countermeasure is a subclass of pko:Procedure, representing remediation procedures in the specified layer. mqto:CountermeasureStep aligns with p-plan:Step for individual actions. In the actual layer, mqto:CountermeasureExecution extends pko:ProcedureExecution and mqto:CountermeasureStepExecution extends pko:StepExecution. Both ontologies follow a specification/execution (plan/actual) pattern, though mqto uses LIS (lis:Specified/lis:Actual with lis:implements) while PKO uses P-PLAN/PROV (with pko:executesProcedure/pko:executesStep). Key architectural difference: mqto externalizes step ordering via mqto:List containers for step reusability across procedures, while PKO embeds ordering directly in steps via pko:nextStep properties."@en ;
                         rdfs:isDefinedBy <https://w3id.org/mqto/1.0> ;
                         rdfs:label "Manufacturing Quality Troubleshooting Ontology"@en ;
                         owl:versionInfo "1.0.0" ;
                         foaf:homepage <https://dg-assist.github.io/mqto/> .


#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/mqto#appearedOn
mqto:appearedOn rdf:type owl:ObjectProperty ;
                rdfs:domain mqto:FailureOccurrence ;
                rdfs:range mqto:ActualIshikawaItem ;
                rdfs:comment "Links a FailureOccurrence to the specific ActualIshikawaItem where it manifested. In MQTO, ActualIshikawaItems are PhysicalMachine, PhysicalMaterial, and ProcessExecution; domain-specific ontologies may add actual-layer counterparts for Manpower and Measurement. Establishes the concrete location or context of the failure event in the actual layer."@en ;
                rdfs:label "appeared on"@en .


###  https://w3id.org/mqto#baseFor
mqto:baseFor rdf:type owl:ObjectProperty ;
             owl:inverseOf mqto:basedOn ;
             rdfs:domain mqto:Observation ;
             rdfs:range mqto:MetricAssessment ;
             rdfs:comment "Indicates that an Observation serves as the data foundation for a MetricAssessment calculation. Inverse of basedOn. Enables tracing from raw sensor data to computed metrics."@en ;
             rdfs:label "base for"@en .


###  https://w3id.org/mqto#basedOn
mqto:basedOn rdf:type owl:ObjectProperty ;
             rdfs:domain mqto:MetricAssessment ;
             rdfs:range mqto:Observation ;
             rdfs:comment "Links a MetricAssessment to the Observation(s) used as input data for its calculation. Establishes the data provenance chain from raw sensor readings to computed metrics. Inverse of baseFor."@en ;
             rdfs:label "based on"@en .


###  https://w3id.org/mqto#calculatedFor
mqto:calculatedFor rdf:type owl:ObjectProperty ;
                   rdfs:domain mqto:MetricAssessment ;
                   rdfs:range mqto:ActualIshikawaItem ;
                   rdfs:comment "Links a MetricAssessment to the specific ActualIshikawaItem it evaluates. In MQTO, ActualIshikawaItems are PhysicalMachine, PhysicalMaterial, and ProcessExecution; domain-specific ontologies may add actual-layer counterparts for Manpower and Measurement. Establishes which concrete entity the metric calculation applies to in the actual layer."@en ;
                   rdfs:label "calculated for"@en .


###  https://w3id.org/mqto#causedBy
mqto:causedBy rdf:type owl:ObjectProperty ;
              owl:inverseOf mqto:causes ;
              rdfs:domain mqto:FailureMode ;
              rdfs:range mqto:FailureMode ;
              rdfs:comment "Links a Failure Mode to another Failure Mode that causes it, forming a causal chain in root cause analysis. This general property has three sub-properties (causedByWeakly, causedByModerately, causedByStrongly) to express different causal strengths. Inverse of causes."@en ;
              rdfs:label "caused by"@en .


###  https://w3id.org/mqto#causedByModerately
mqto:causedByModerately rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf mqto:causedBy ;
                        owl:inverseOf mqto:causesModerately ;
                        rdfs:comment "Indicates a moderate-strength causal relationship where one Failure Mode is caused by another with medium probability or influence. Enables ordinal ranking of causal strengths without requiring precise numeric probabilities. Subproperty of causedBy."@en ;
                        rdfs:label "caused by moderately"@en .


###  https://w3id.org/mqto#causedByStrongly
mqto:causedByStrongly rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf mqto:causedBy ;
                      owl:inverseOf mqto:causesStrongly ;
                      rdfs:comment "Indicates a strong causal relationship where one Failure Mode is caused by another with high probability or significant influence. Enables ordinal ranking of causal strengths without requiring precise numeric probabilities. Subproperty of causedBy."@en ;
                      rdfs:label "caused by strongly"@en .


###  https://w3id.org/mqto#causedByWeakly
mqto:causedByWeakly rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf mqto:causedBy ;
                    owl:inverseOf mqto:causesWeakly ;
                    rdfs:comment "Indicates a weak causal relationship where one Failure Mode is caused by another with low probability or minor influence. Enables ordinal ranking of causal strengths without requiring precise numeric probabilities. Subproperty of causedBy."@en ;
                    rdfs:label "caused by weakly"@en .


###  https://w3id.org/mqto#causes
mqto:causes rdf:type owl:ObjectProperty ;
            rdfs:domain mqto:FailureMode ;
            rdfs:range mqto:FailureMode ;
            rdfs:comment "Links a Failure Mode to another Failure Mode that it causes, forming a causal chain in root cause analysis. This general property has three sub-properties (causesWeakly, causesModerately, causesStrongly) to express different causal strengths. Inverse of causedBy."@en ;
            rdfs:label "causes"@en .


###  https://w3id.org/mqto#causesModerately
mqto:causesModerately rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf mqto:causes ;
                      rdfs:comment "Indicates a moderate-strength causal relationship where one Failure Mode causes another with medium probability or influence. Enables ordinal ranking of causal strengths without requiring precise numeric probabilities. Subproperty of causes."@en ;
                      rdfs:label "causes moderately"@en .


###  https://w3id.org/mqto#causesStrongly
mqto:causesStrongly rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf mqto:causes ;
                    rdfs:comment "Indicates a strong causal relationship where one Failure Mode causes another with high probability or significant influence. Enables ordinal ranking of causal strengths without requiring precise numeric probabilities. Subproperty of causes."@en ;
                    rdfs:label "causes strongly"@en .


###  https://w3id.org/mqto#causesWeakly
mqto:causesWeakly rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf mqto:causes ;
                  rdfs:comment "Indicates a weak causal relationship where one Failure Mode causes another with low probability or minor influence. Enables ordinal ranking of causal strengths without requiring precise numeric probabilities. Subproperty of causes."@en ;
                  rdfs:label "causes weakly"@en .


###  https://w3id.org/mqto#evaluatedBy
mqto:evaluatedBy rdf:type owl:ObjectProperty ;
                 owl:inverseOf mqto:evaluatesProperty ;
                 rdfs:domain mqto:ObservableProperty ;
                 rdfs:range mqto:MetricAssessment ;
                 rdfs:comment "Relates an ObservableProperty to the MetricAssessment that evaluated it (actual layer). Inverse of mqto:evaluatesProperty. Counterpart to mqto:readBy in the specified layer."@en ;
                 rdfs:label "evaluated by"@en .


###  https://w3id.org/mqto#evaluatesProperty
mqto:evaluatesProperty rdf:type owl:ObjectProperty ;
                       rdfs:domain mqto:MetricAssessment ;
                       rdfs:range mqto:ObservableProperty ;
                       rdfs:comment "Relates a MetricAssessment to the ObservableProperty it evaluated (actual layer). Counterpart to mqto:readsFrom, which relates a Metric to a Signal in the specified layer."@en ;
                       rdfs:label "evaluates property"@en .


###  https://w3id.org/mqto#failureBelongsTo
mqto:failureBelongsTo rdf:type owl:ObjectProperty ;
                      owl:inverseOf mqto:hasFailure ;
                      rdfs:domain mqto:FailureMode ;
                      rdfs:range mqto:IshikawaItem ;
                      rdfs:comment "Associates a Failure Mode with the IshikawaItem (Machine, Manpower, Material, Measurement, or Method) category it belongs to in the fishbone diagram structure. Establishes which root cause category the failure is classified under. Inverse of hasFailure."@en ;
                      rdfs:label "failure belongs to"@en .


###  https://w3id.org/mqto#first
mqto:first rdf:type owl:ObjectProperty ;
           rdfs:domain mqto:List ;
           rdfs:range mqto:CountermeasureStep ;
           rdfs:comment "Points to the first CountermeasureStep in a reusable ordered list. Analogous to rdf:first but defined as an explicit OWL object property with proper domain/range constraints. The list structure (rather than a direct step-to-step chain) allows the same CountermeasureStep instance to appear in multiple Countermeasure procedures without embedding order into the step itself."@en ;
           rdfs:label "first"@en .


###  https://w3id.org/mqto#hasFailure
mqto:hasFailure rdf:type owl:ObjectProperty ;
                rdfs:domain mqto:IshikawaItem ;
                rdfs:range mqto:FailureMode ;
                rdfs:comment "Associates an IshikawaItem (Machine, Manpower, Material, Measurement, or Method) with a Failure Mode that can occur in that category. Establishes which failures belong to each root cause category in the fishbone diagram structure. Inverse of failureBelongsTo."@en ;
                rdfs:label "has failure"@en .


###  https://w3id.org/mqto#hasFirstStep
mqto:hasFirstStep rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf mqto:hasStep ;
                  rdfs:domain mqto:CountermeasureExecution ;
                  rdfs:range mqto:CountermeasureStepExecution ;
                  rdfs:comment "Points to the first CountermeasureStepExecution in the concrete execution chain. In the actual layer, steps are performed in a fixed linear order and are not reused, so the order is encoded directly in the chain via mqto:hasNextStep."@en ;
                  rdfs:label "has first step"@en .


###  https://w3id.org/mqto#hasMetric
mqto:hasMetric rdf:type owl:ObjectProperty ;
               owl:inverseOf mqto:metricBelongsTo ;
               rdfs:domain mqto:IshikawaItem ;
               rdfs:range mqto:Metric ;
               rdfs:comment "Associates an IshikawaItem (Machine, Manpower, Material, Measurement, or Method) with a Metric used to monitor or assess that category. Establishes which metrics are relevant for monitoring each root cause category. Inverse of metricBelongsTo."@en ;
               rdfs:label "has metric"@en .


###  https://w3id.org/mqto#hasNextStep
mqto:hasNextStep rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf mqto:hasStep ;
                 rdfs:domain mqto:CountermeasureStepExecution ;
                 rdfs:range mqto:CountermeasureStepExecution ;
                 rdfs:comment "Links one CountermeasureStepExecution to the next in the concrete execution sequence. Unlike the specified layer (which uses mqto:List for reusability), the actual execution occurs once in a specific order, so step-to-step chaining is appropriate here."@en ;
                 rdfs:label "has next step"@en .


###  https://w3id.org/mqto#hasStep
mqto:hasStep rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf lis:hasActivityPart ;
             rdfs:range mqto:CountermeasureStepExecution ;
             rdfs:comment "Links a CountermeasureExecution to its constituent CountermeasureStepExecutions in the actual layer. General property for all steps; hasFirstStep identifies the starting step, and hasNextStep chains the sequence. Subproperty of lis:hasActivityPart. No global rdfs:domain is declared; the source class is constrained by the allValuesFrom restriction on CountermeasureExecution, avoiding unintended domain inferences on hasNextStep (which is a subproperty)."@en ;
             rdfs:label "has step"@en .


###  https://w3id.org/mqto#metricBelongsTo
mqto:metricBelongsTo rdf:type owl:ObjectProperty ;
                     rdfs:domain mqto:Metric ;
                     rdfs:range mqto:IshikawaItem ;
                     rdfs:comment "Associates a Metric with the IshikawaItem (Machine, Manpower, Material, Measurement, or Method) category it monitors or assesses. Establishes which root cause category a metric is used for. Inverse of hasMetric."@en ;
                     rdfs:label "metric belongs to"@en .


###  https://w3id.org/mqto#metricReferredBy
mqto:metricReferredBy rdf:type owl:ObjectProperty ;
                      owl:inverseOf mqto:refersToMetric ;
                      rdfs:domain mqto:Metric ;
                      rdfs:range mqto:FailureMode ;
                      rdfs:comment "Indicates that a Metric is referred to by a Failure Mode for diagnostic purposes. Establishes which failures use which metrics for detection or characterization. Inverse of refersToMetric."@en ;
                      rdfs:label "metric referred by"@en .


###  https://w3id.org/mqto#mitigated
mqto:mitigated rdf:type owl:ObjectProperty ;
               rdfs:domain mqto:CountermeasureExecution ;
               rdfs:range mqto:FailureOccurrence ;
               rdfs:comment "A countermeasure execution mitigated a failure occurrence. Note: this is the actual-layer forward property (past participle). The specified-layer equivalent uses mqto:mitigates (active voice). The naming difference is intentional: 'mitigated' records a completed fact at instance level, while 'mitigates' expresses a general capability at schema level."@en ;
               rdfs:label "mitigated"@en .


###  https://w3id.org/mqto#mitigatedBy
mqto:mitigatedBy rdf:type owl:ObjectProperty ;
                 owl:inverseOf mqto:mitigates ;
                 rdfs:domain mqto:FailureMode ;
                 rdfs:range mqto:Countermeasure ;
                 rdfs:comment "Links a Failure Mode to a Countermeasure that can remediate or reduce it (specified layer). Establishes which remediation procedures are applicable for addressing specific failure types. Inverse of mitigates. The actual-layer counterpart is mqto:mitigated (domain: CountermeasureExecution, range: FailureOccurrence), which uses a distinct property to avoid range conflicts between the two layers."@en ;
                 rdfs:label "mitigated by"@en .


###  https://w3id.org/mqto#mitigates
mqto:mitigates rdf:type owl:ObjectProperty ;
               rdfs:domain mqto:Countermeasure ;
               rdfs:range mqto:FailureMode ;
               rdfs:comment "Links a Countermeasure to the Failure Mode(s) it can remediate or reduce (specified layer). Establishes which failure types a remediation procedure addresses. Inverse of mitigatedBy. The actual-layer equivalent links CountermeasureExecution to FailureOccurrence."@en ;
               rdfs:label "mitigates"@en .


###  https://w3id.org/mqto#providesSignal
mqto:providesSignal rdf:type owl:ObjectProperty ;
                    owl:inverseOf mqto:signalProvidedBy ;
                    rdfs:domain mqto:IshikawaItem ;
                    rdfs:range mqto:Signal ;
                    rdfs:comment "Relates an IshikawaItem (Machine, Manpower, Material, Measurement, or Method) to the data channels (Signals) associated with it. A Signal may be an output channel carrying measurement data from the item (e.g. a temperature sensor reading) or an input channel carrying control data to the item (e.g. a setpoint or actuator command). The Signal is a specified channel descriptor; actual observations are made via sosa:Observation on the corresponding ActualIshikawaItem."@en ;
                    rdfs:label "provides signal"@en .


###  https://w3id.org/mqto#raised
mqto:raised rdf:type owl:ObjectProperty ;
            owl:inverseOf mqto:raisedBy ;
            rdfs:domain mqto:MetricAssessment ;
            rdfs:range mqto:FailureOccurrence ;
            rdfs:comment "Links a MetricAssessment to the FailureOccurrence it detected or triggered. Establishes which failures were raised by threshold violations in metric evaluations. Inverse of raisedBy."@en ;
            rdfs:label "raised"@en .


###  https://w3id.org/mqto#raisedBy
mqto:raisedBy rdf:type owl:ObjectProperty ;
              rdfs:domain mqto:FailureOccurrence ;
              rdfs:range mqto:MetricAssessment ;
              rdfs:comment "Links a FailureOccurrence to the MetricAssessment(s) that detected or triggered it. Establishes which metric evaluations identified the failure through threshold violations. Inverse of raised."@en ;
              rdfs:label "raised by"@en .


###  https://w3id.org/mqto#readBy
mqto:readBy rdf:type owl:ObjectProperty ;
            owl:inverseOf mqto:readsFrom ;
            rdfs:domain mqto:Signal ;
            rdfs:range mqto:Metric ;
            rdfs:comment "Relates a Signal (data channel) to the Metric that is computed from it (specified layer). Inverse of mqto:readsFrom. For the actual-layer counterpart see mqto:evaluatedBy."@en ;
            rdfs:label "read by"@en .


###  https://w3id.org/mqto#readsFrom
mqto:readsFrom rdf:type owl:ObjectProperty ;
               rdfs:domain mqto:Metric ;
               rdfs:range mqto:Signal ;
               rdfs:comment "Relates a Metric to the Signal (data channel) it is computed from (specified layer). Inverse of mqto:readBy. For the actual-layer counterpart see mqto:evaluatesProperty."@en ;
               rdfs:label "reads from"@en .


###  https://w3id.org/mqto#refersToMetric
mqto:refersToMetric rdf:type owl:ObjectProperty ;
                    rdfs:domain mqto:FailureMode ;
                    rdfs:range mqto:Metric ;
                    rdfs:comment "Links a Failure Mode to the Metric(s) used for its detection or characterization. Establishes which quantitative assessments are diagnostic indicators for specific failure types. Inverse of metricReferredBy."@en ;
                    rdfs:label "refers to metric"@en .


###  https://w3id.org/mqto#rest
mqto:rest rdf:type owl:ObjectProperty ;
          rdfs:domain mqto:List ;
          rdfs:range mqto:List ;
          rdfs:comment "Points to the remainder of the ordered step list. Analogous to rdf:rest but defined as an explicit OWL object property with proper domain/range constraints for better reasoner compatibility. Together with mqto:first, this implements a reusable linked-list container so that step order is encoded in the list, not in the steps themselves. The list must terminate at mqto:nil; circular references are not permitted, though OWL cannot formally enforce acyclicity."@en ;
          rdfs:label "rest"@en .


###  https://w3id.org/mqto#resultProperty
mqto:resultProperty rdf:type owl:ObjectProperty ;
                    rdfs:domain mqto:Metric ;
                    rdfs:range rdf:Property ;
                    rdfs:comment "Specifies which data property of mqto:Result instances should be read when computing this Metric. A single Result instance commonly carries multiple measured values as separate data properties (e.g., ex:temperature, ex:pressure, ex:cycleTime on one PLC-cycle Result). Each Metric declares its resultProperty to select exactly one of those properties: a TemperatureMetric sets resultProperty to ex:temperature, while a PressureMetric on the same observations sets it to ex:pressure. At query time, an application reads ?metric mqto:resultProperty ?prop and then retrieves ?result ?prop ?value for each Result in the time window. Note: this is a meta-level construct — an object property whose value is itself a property — which falls outside normal OWL type-system validation. It is retained because it provides a simple, declarative way to parameterise Metrics without requiring SPARQL property-path strings or a SHACL infrastructure at the schema level."@en ;
                    rdfs:label "result property"@en ;
                    <http://www.w3.org/2004/02/skos/core#example> """A PLC cycle produces one Result with three data properties:
  ex:Result_Shot042  ex:temperature  718.3 ;
                     ex:pressure     980.0 ;
                     ex:cycleTime     24.7 .

Two Metrics select different properties from the same Result:
  ex:TemperatureMetric  mqto:resultProperty  ex:temperature .
  ex:PressureMetric     mqto:resultProperty  ex:pressure .

At query time: SELECT ?value WHERE { ?metric mqto:resultProperty ?prop . ?result ?prop ?value . }"""@en .


###  https://w3id.org/mqto#signalProvidedBy
mqto:signalProvidedBy rdf:type owl:ObjectProperty ;
                      rdfs:domain mqto:Signal ;
                      rdfs:range mqto:IshikawaItem ;
                      rdfs:comment "Associates a Signal (data channel) with the IshikawaItem (Machine, Manpower, Material, Measurement, or Method) that provides it. Establishes the source of measurement or control data channels. Inverse of providesSignal."@en ;
                      rdfs:label "signal provided by"@en .


###  https://w3id.org/mqto#hasStepList
mqto:hasStepList rdf:type owl:ObjectProperty ;
                 rdfs:domain mqto:Countermeasure ;
                 rdfs:range mqto:List ;
                 rdfs:comment "Links a Countermeasure to its ordered list of steps (mqto:List). The indirection via mqto:List enables the same CountermeasureStep to be referenced in multiple Countermeasure definitions (reuse across procedures). Named hasStepList rather than hasStep to distinguish it from pko:hasStep, which links directly to step instances rather than to a list container."@en ;
                 rdfs:label "has step list"@en .


###  https://w3id.org/mqto#suggested
mqto:suggested rdf:type owl:ObjectProperty ;
               owl:inverseOf mqto:suggestedBy ;
               rdfs:domain mqto:FailureOccurrence ;
               rdfs:range mqto:CountermeasureExecution ;
               rdfs:comment "A failure occurrence suggested a countermeasure execution."@en ;
               rdfs:label "suggested"@en .


###  https://w3id.org/mqto#suggestedBy
mqto:suggestedBy rdf:type owl:ObjectProperty ;
                 rdfs:domain mqto:CountermeasureExecution ;
                 rdfs:range mqto:FailureOccurrence ;
                 rdfs:comment "A countermeasure execution was suggested by a failure occurrence."@en ;
                 rdfs:label "suggested by"@en .


#################################################################
#    Data properties
#################################################################

###  https://w3id.org/mqto#abortedReason
mqto:abortedReason rdf:type owl:DatatypeProperty ;
                   rdfs:range xsd:string ;
                   rdfs:comment "Human-readable explanation of why a CountermeasureStepExecution or CountermeasureExecution was aborted before completion. Provides context for interrupted remediation procedures."@en ;
                   rdfs:label "aborted reason"@en .


###  https://w3id.org/mqto#abortedTime
mqto:abortedTime rdf:type owl:DatatypeProperty ;
                 rdfs:range xsd:dateTime ;
                 rdfs:comment "The timestamp when a CountermeasureStepExecution or CountermeasureExecution was aborted. Records the moment the procedure was interrupted before normal completion."@en ;
                 rdfs:label "aborted time"@en .


###  https://w3id.org/mqto#assessmentValue
mqto:assessmentValue rdf:type owl:DatatypeProperty ;
                     rdfs:domain mqto:MetricAssessment ;
                     rdfs:range xsd:boolean ;
                     rdfs:comment "Boolean pass/fail decision resulting from comparing the calculatedValue against the Metric's threshold bounds (lowerBound/upperBound). True indicates a threshold violation (failure condition detected), false indicates normal operation within bounds."@en ;
                     rdfs:label "assessment value"@en .


###  https://w3id.org/mqto#calculatedTime
mqto:calculatedTime rdf:type owl:DatatypeProperty ;
                    rdfs:domain mqto:MetricAssessment ;
                    rdfs:range xsd:dateTime ;
                    rdfs:comment "The timestamp when a MetricAssessment was computed. Marks the moment the metric calculation was performed and the threshold comparison was evaluated, which may differ from the time window of the underlying observations."@en ;
                    rdfs:label "calculated time"@en .


###  https://w3id.org/mqto#calculatedValue
mqto:calculatedValue rdf:type owl:DatatypeProperty ;
                     rdfs:domain mqto:MetricAssessment ;
                     rdfs:range xsd:double ;
                     rdfs:comment "The actual computed numeric value of the metric assessment. This preserves the quantitative result before threshold comparison, enabling trend analysis, statistical modeling, and root cause correlation. For example, if a temperature metric calculates 85.7°C and the upperBound is 80°C, calculatedValue is 85.7 while assessmentValue would be true (indicating a violation). The unit of measurement is inherited from the implemented Metric specification."@en ;
                     rdfs:label "calculated value"@en .


###  https://w3id.org/mqto#completionTime
mqto:completionTime rdf:type owl:DatatypeProperty ;
                    rdfs:domain mqto:CountermeasureStepExecution ;
                    rdfs:range xsd:dateTime ;
                    rdfs:comment "The timestamp when a CountermeasureStepExecution was successfully completed. Marks the end of a remediation step's execution. If a step is aborted, abortedTime should be used instead."@en ;
                    rdfs:label "completion time"@en .


###  https://w3id.org/mqto#endTime
mqto:endTime rdf:type owl:DatatypeProperty ;
             rdfs:range xsd:dateTime ;
             rdfs:comment "The timestamp when an activity or time-bound entity concluded. General-purpose temporal property applicable to various execution contexts including ProcessExecution, CountermeasureExecution, and time windows."@en ;
             rdfs:label "end time"@en .


###  https://w3id.org/mqto#identifier
mqto:identifier rdf:type owl:DatatypeProperty ;
                rdfs:comment "A unique identifier for an entity such as a machine serial number, material batch code, signal name, or process ID. Conceptually aligned with dcterms:identifier but declared as an independent OWL DatatypeProperty (rdfs:subPropertyOf is not used because dcterms:identifier is an annotation property and OWL 2 DL does not permit a datatype property to be a subproperty of an annotation property). Enables correlation between ontology instances and external systems (ERP, MES, SCADA)."@en ;
                rdfs:label "identifier"@en ;
                rdfs:seeAlso dcterms:identifier .


###  https://w3id.org/mqto#lowerBound
mqto:lowerBound rdf:type owl:DatatypeProperty ;
                rdfs:domain mqto:Metric ;
                rdfs:range xsd:double ;
                rdfs:comment "The minimum acceptable threshold value for a Metric, as a dimensionless double. MetricAssessments compare their calculatedValue against this bound; values below the lowerBound indicate a threshold violation. The unit of measurement is determined by the Metric's associated Signal."@en ;
                rdfs:label "lower bound"@en .


###  https://w3id.org/mqto#markdownContent
mqto:markdownContent rdf:type owl:DatatypeProperty ;
                     rdfs:domain [ rdf:type owl:Class ;
                                   owl:unionOf ( mqto:Countermeasure
                                                 mqto:CountermeasureStep
                                               )
                                 ] ;
                     rdfs:range xsd:string ;
                     rdfs:comment "Detailed procedural instructions or documentation in Markdown format. Used for Countermeasure and CountermeasureStep to provide rich-text descriptions, images, checklists, and formatting for human-readable remediation guidance."@en ;
                     rdfs:label "markdown content"@en .


###  https://w3id.org/mqto#measValue
mqto:measValue rdf:type owl:DatatypeProperty ;
               rdfs:domain mqto:Result ;
               rdfs:range xsd:double ;
               rdfs:comment "The numeric measured value contained in an Observation Result. Represents a single data point from a sensor or data source. This property can be referenced by Metric.resultProperty to extract values for metric calculations."@en ;
               rdfs:label "measurement value"@en .


###  https://w3id.org/mqto#method
mqto:method rdf:type owl:DatatypeProperty ;
            rdfs:domain mqto:Metric ;
            rdfs:comment "The assessment or calculation method applied by a Metric to compute its value from observations. Describes the algorithm or statistical function (e.g., 'average', 'maximum', 'standard deviation', 'trend slope') used to aggregate or analyze data within the time window."@en ;
            rdfs:label "method"@en .


###  https://w3id.org/mqto#occurrenceTime
mqto:occurrenceTime rdf:type owl:DatatypeProperty ;
                    rdfs:domain mqto:FailureOccurrence ;
                    rdfs:range xsd:dateTime ;
                    rdfs:comment "The timestamp when this failure occurrence actually happened in the physical world. Essential for failure frequency analysis, MTBF calculations, and temporal correlation with process events and observations."@en ;
                    rdfs:label "occurrence time"@en .


###  https://w3id.org/mqto#reasoningLine
mqto:reasoningLine rdf:type owl:DatatypeProperty ;
                   rdfs:domain mqto:CountermeasureExecution ;
                   rdfs:range xsd:string ;
                   rdfs:comment "Human-readable explanation of why a particular CountermeasureExecution was selected or recommended. Documents the diagnostic reasoning chain linking observed failures to the chosen remediation procedure, supporting auditability and knowledge capture."@en ;
                   rdfs:label "reasoning line"@en .


###  https://w3id.org/mqto#role
mqto:role rdf:type owl:DatatypeProperty ;
          rdfs:domain mqto:CountermeasureStep ;
          rdfs:range xsd:string ;
          rdfs:comment "The responsible role or job function that should perform a CountermeasureStep (e.g., 'operator', 'maintenance technician', 'quality inspector'). Enables workflow assignment and ensures appropriate expertise for remediation tasks."@en ;
          rdfs:label "role"@en .


###  https://w3id.org/mqto#score
mqto:score rdf:type owl:DatatypeProperty ;
           rdfs:domain mqto:CountermeasureExecution ;
           rdfs:range xsd:double ;
           rdfs:comment "A numeric score or confidence value assigned to a CountermeasureExecution recommendation. Used by diagnostic systems to rank countermeasure suggestions based on relevance, likelihood of success, or other scoring criteria. The interpretation and scale of scores is application-specific."@en ;
           rdfs:label "score"@en .


###  https://w3id.org/mqto#startTime
mqto:startTime rdf:type owl:DatatypeProperty ;
               rdfs:range xsd:dateTime ;
               rdfs:comment "The timestamp when an activity or time-bound entity began. General-purpose temporal property applicable to various execution contexts including ProcessExecution, CountermeasureExecution, and time windows."@en ;
               rdfs:label "start time"@en .


###  https://w3id.org/mqto#timeWindowSize
mqto:timeWindowSize rdf:type owl:DatatypeProperty ;
                    rdfs:domain mqto:Metric ;
                    rdfs:range xsd:duration ;
                    rdfs:comment "The duration of the time window over which a Metric aggregates observations for calculation, expressed as an xsd:duration value (e.g., \"PT5M\"^^xsd:duration for 5 minutes, \"PT1H\"^^xsd:duration for 1 hour). Defines how far back in time from the calculatedTime the metric should consider observation data."@en ;
                    rdfs:label "time window size"@en .


###  https://w3id.org/mqto#upperBound
mqto:upperBound rdf:type owl:DatatypeProperty ;
                rdfs:domain mqto:Metric ;
                rdfs:range xsd:double ;
                rdfs:comment "The maximum acceptable threshold value for a Metric, as a dimensionless double. MetricAssessments compare their calculatedValue against this bound; values above the upperBound indicate a threshold violation. The unit of measurement is determined by the Metric's associated Signal."@en ;
                rdfs:label "upper bound"@en .


###  https://w3id.org/mqto#weight
mqto:weight rdf:type owl:DatatypeProperty ;
            rdfs:domain [ rdf:type owl:Class ;
                          owl:unionOf ( mqto:Countermeasure
                                        mqto:FailureMode
                                      )
                        ] ;
            rdfs:range xsd:int ;
            rdfs:comment "A relative ranking weight assigned to a Failure Mode or Countermeasure. For Failure Modes, indicates severity or priority. For Countermeasures, indicates effectiveness or preference. Provides anchor points for external ranking logic; the ontology does not prescribe the ranking algorithm itself."@en ;
            rdfs:label "weight"@en .


#################################################################
#    Classes
#################################################################

###  http://www.w3.org/1999/02/22-rdf-syntax-ns#Property
rdf:Property rdf:type owl:Class .


###  http://www.w3.org/ns/sosa/ActuableProperty
sosa:ActuableProperty rdf:type owl:Class .


###  https://w3id.org/mqto#ActuableProperty
mqto:ActuableProperty rdf:type owl:Class ;
                      rdfs:subClassOf sosa:ActuableProperty ,
                                      mqto:Property ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty ssn:isPropertyOf ;
                                        owl:allValuesFrom mqto:ActualIshikawaItem
                                      ] ;
                      rdfs:comment "An actuable property of an ActualIshikawaItem that can be controlled or modified via Actuations. As a subclass of mqto:Property, it implements a Signal specification from the specified layer. Represents properties that can be set or modified, such as setpoints, valve positions, motor speeds, or control commands. The Signal in the specified layer defines the control channel metadata, while ActuableProperty represents the actual controllable quality of a specific feature of interest."@en ;
                      rdfs:label "Actuable Property"@en .


###  https://w3id.org/mqto#ActualIshikawaItem
mqto:ActualIshikawaItem rdf:type owl:Class ;
                        rdfs:subClassOf lis:Actual ,
                                        sosa:FeatureOfInterest ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty sosa:isFeatureOfInterestOf ;
                                          owl:allValuesFrom mqto:Observation
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty ssn:hasProperty ;
                                          owl:allValuesFrom mqto:ObservableProperty
                                        ] ;
                        rdfs:comment "Abstract superclass for actual/instance layer counterparts of IshikawaItem. Integrates SOSA: each ActualIshikawaItem is a FeatureOfInterest that can be observed, has ObservableProperties, and can have FailureOccurrences. MQTO defines three concrete subclasses: PhysicalMachine (implements Machine), PhysicalMaterial (implements Material), and ProcessExecution (implements Method). Actual-layer counterparts for Manpower and Measurement are not defined in MQTO; domain-specific ontologies are expected to provide them."@en ;
                        rdfs:label "Actual Ishikawa Item"@en .


###  https://w3id.org/mqto#Countermeasure
mqto:Countermeasure rdf:type owl:Class ;
                    rdfs:subClassOf lis:Activity ,
                                    lis:Specified ,
                                    pko:Procedure ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty mqto:hasStepList ;
                                      owl:someValuesFrom mqto:List
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty lis:hasParticipant ;
                                      owl:allValuesFrom [ rdf:type owl:Class ;
                                                          owl:unionOf ( mqto:Machine
                                                                        mqto:Manpower
                                                                        mqto:Material
                                                                      )
                                                        ]
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty mqto:mitigates ;
                                      owl:allValuesFrom mqto:FailureMode
                                    ] ;
                    rdfs:comment "A remediation procedure that mitigates one or more Failure Modes. Countermeasures are structured as ordered sequences of CountermeasureSteps, represented via the mqto:List pattern for reusability. As a subclass of pko:Procedure, countermeasures align with the Procedural Knowledge Ontology's procedure modeling patterns while maintaining integration with the LIS specified/actual architecture."@en ;
                    rdfs:label "Countermeasure"@en .


###  https://w3id.org/mqto#CountermeasureExecution
mqto:CountermeasureExecution rdf:type owl:Class ;
                             rdfs:subClassOf lis:Activity ,
                                             lis:Actual ,
                                             pko:ProcedureExecution ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty lis:implements ;
                                               owl:someValuesFrom mqto:Countermeasure
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty mqto:hasStep ;
                                               owl:allValuesFrom mqto:CountermeasureStepExecution
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty mqto:mitigated ;
                                               owl:allValuesFrom mqto:FailureOccurrence
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty mqto:suggestedBy ;
                                               owl:allValuesFrom mqto:FailureOccurrence
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty mqto:hasFirstStep ;
                                               owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                               owl:onClass mqto:CountermeasureStepExecution
                                             ] ;
                             rdfs:comment "The actual execution of a Countermeasure procedure, performed to mitigate one or more FailureOccurrences. As a subclass of both lis:Activity and lis:Actual, it is a concrete temporal event that implements a Countermeasure specification. Links to the Countermeasure via lis:implements, records mitigated FailureOccurrences via mqto:mitigated, and tracks constituent steps via mqto:hasStep. Participants (machines, materials, or personnel) are not constrained at the MQTO level; the participant restriction is carried by the Countermeasure specification, and domain-specific ontologies may further restrict or extend participation. As a subclass of pko:ProcedureExecution, countermeasure executions align with PKO's procedure execution model."@en ;
                             rdfs:label "Countermeasure Execution"@en .


###  https://w3id.org/mqto#CountermeasureStep
mqto:CountermeasureStep rdf:type owl:Class ;
                        rdfs:subClassOf p-plan:Step ,
                                        lis:Activity ,
                                        lis:Specified ;
                        rdfs:comment "A reusable specification of a single step within a Countermeasure procedure. Because the same step (e.g. 'clean the mould') may occur in multiple Countermeasures, ordering is not encoded in the step itself but in the mqto:List that references it. As a subclass of p-plan:Step, countermeasure steps align with the P-PLAN ontology for plan-based activity modeling."@en ;
                        rdfs:label "Countermeasure Step"@en .


###  https://w3id.org/mqto#CountermeasureStepExecution
mqto:CountermeasureStepExecution rdf:type owl:Class ;
                                 rdfs:subClassOf lis:Activity ,
                                                 lis:Actual ,
                                                 pko:StepExecution ,
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty lis:implements ;
                                                   owl:someValuesFrom mqto:CountermeasureStep
                                                 ] ;
                                 rdfs:comment "The actual, single execution of one CountermeasureStep. Each execution implements a specific CountermeasureStep from the specified layer via lis:implements, performed in a concrete, non-reused linear order encoded via mqto:hasFirstStep / mqto:hasNextStep, contrasting with the specified layer where mqto:List enables step reuse across procedures. As a subclass of both lis:Activity and lis:Actual, it is a concrete temporal activity. As a subclass of pko:StepExecution, countermeasure step executions align with PKO's step execution model."@en ;
                                 rdfs:label "Countermeasure Step Execution"@en .


###  https://w3id.org/mqto#FailureMode
mqto:FailureMode rdf:type owl:Class ;
                 rdfs:subClassOf lis:Specified ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty mqto:failureBelongsTo ;
                                   owl:someValuesFrom mqto:IshikawaItem
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty mqto:causedBy ;
                                   owl:allValuesFrom mqto:FailureMode
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty mqto:causes ;
                                   owl:allValuesFrom mqto:FailureMode
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty mqto:failureBelongsTo ;
                                   owl:allValuesFrom mqto:IshikawaItem
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty mqto:mitigatedBy ;
                                   owl:allValuesFrom mqto:Countermeasure
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty mqto:refersToMetric ;
                                   owl:allValuesFrom mqto:Metric
                                 ] ;
                 rdfs:comment "A manner in which a manufacturing component, system, or process could potentially fail to meet its intended function or quality requirements (specified layer). Aligns with FMEA terminology per IEC 60812:2018. Belongs to an IshikawaItem (Machine, Manpower, Material, Measurement, or Method category), refers to diagnostic Metrics, and can be mitigated by Countermeasures. Failure Modes can have causal relationships with other Failure Modes (causes/causedBy) to model root cause chains. The actual-layer counterpart is FailureOccurrence."@en ;
                 rdfs:label "Failure Mode"@en .


###  https://w3id.org/mqto#FailureOccurrence
mqto:FailureOccurrence rdf:type owl:Class ;
                       rdfs:subClassOf lis:Activity ,
                                       lis:Actual ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty lis:implements ;
                                         owl:someValuesFrom mqto:FailureMode
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty mqto:appearedOn ;
                                         owl:someValuesFrom mqto:ActualIshikawaItem
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty mqto:raisedBy ;
                                         owl:allValuesFrom mqto:MetricAssessment
                                       ] ;
                       rdfs:comment "An instance-layer temporal event representing a specific quality defect or operational problem detected during production. As a subclass of both lis:Activity and lis:Actual, it is a concrete occurrence in time. Implements a Failure Mode specification, appears on an ActualIshikawaItem, and is raised by one or more MetricAssessments that detected threshold violations. Can be mitigated by CountermeasureExecutions. The timestamp of the occurrence is recorded via mqto:occurrenceTime."@en ;
                       rdfs:label "Failure Occurrence"@en .


###  https://w3id.org/mqto#IshikawaItem
mqto:IshikawaItem rdf:type owl:Class ;
                  rdfs:subClassOf lis:Specified ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty mqto:hasFailure ;
                                    owl:allValuesFrom mqto:FailureMode
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty mqto:hasMetric ;
                                    owl:allValuesFrom mqto:Metric
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty mqto:providesSignal ;
                                    owl:allValuesFrom mqto:Signal
                                  ] ;
                  rdfs:comment "Abstract superclass for the five categories of root causes in an Ishikawa (fishbone) diagram: Machine, Manpower, Material, Measurement, and Method. Domain-specific ontologies can specialize these concepts for their manufacturing domain."@en ;
                  rdfs:label "Ishikawa Item"@en .


###  https://w3id.org/mqto#List
mqto:List rdf:type owl:Class ;
          rdfs:comment "An ordered, reusable container of CountermeasureSteps within the specified layer. Implements an OWL-native linked list pattern (mqto:first / mqto:rest) inspired by RDF Collections, but using explicit OWL class and property definitions for better reasoner compatibility. Standard rdf:List creates known issues with OWL reasoners due to blank node handling and recursive structure reasoning. This approach ensures compatibility with standard reasoners such as HermiT and Pellet while maintaining the core benefit: step order is external to the step instances, allowing steps to be shared across different Countermeasure procedures without embedding ordering information in the steps themselves. The list is terminated by mqto:nil. See OWL 2 Primer Section 4.2 on structural specification limitations with blank nodes."@en ;
          rdfs:label "List"@en ;
          rdfs:seeAlso <http://www.w3.org/TR/owl2-primer/> .


###  https://w3id.org/mqto#Machine
mqto:Machine rdf:type owl:Class ;
             rdfs:subClassOf lis:PhysicalArtefact ,
                             mqto:IshikawaItem ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty lis:participantIn ;
                               owl:allValuesFrom mqto:Method
                             ] ;
             rdfs:comment "Manufacturing equipment, tools, and devices (the 'M' in Ishikawa's Machine). Represents specified physical resources that participate in Methods. Domain-specific ontologies can define specific machine types such as cells, furnaces, and robots. Machines provide Signals (sensor readings, control channels) and can have associated Failure Modes and Metrics."@en ;
             rdfs:label "Machine"@en .


###  https://w3id.org/mqto#Manpower
mqto:Manpower rdf:type owl:Class ;
              rdfs:subClassOf mqto:IshikawaItem ;
              rdfs:comment "Workforce, operators, and personnel involved in manufacturing (the 'M' in Ishikawa's Manpower). Represents the specified human resource roles that contribute to manufacturing processes. Domain-specific ontologies can define specific roles such as machine operators, quality inspectors, and process engineers. Manpower can be associated with Failure Modes and Metrics, and participates in Methods as a contributing factor."@en ;
              rdfs:label "Manpower"@en .


###  https://w3id.org/mqto#Material
mqto:Material rdf:type owl:Class ;
              rdfs:subClassOf lis:PhysicalArtefact ,
                              mqto:IshikawaItem ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty lis:participantIn ;
                                owl:allValuesFrom mqto:Method
                              ] ;
              rdfs:comment "Raw materials, consumables, and inputs to manufacturing (the 'M' in Ishikawa's Material). Represents specified material types that participate in Methods. Domain-specific ontologies can define specific material types such as alloys, lubricants, and consumables. Materials can have properties monitored via Signals and associated quality Metrics."@en ;
              rdfs:label "Material"@en .


###  https://w3id.org/mqto#Measurement
mqto:Measurement rdf:type owl:Class ;
                 rdfs:subClassOf sosa:Procedure ,
                                 mqto:IshikawaItem ;
                 rdfs:comment "A measurement procedure or inspection method (the 'M' in Ishikawa's Measurement). Represents the specified procedure for how a quantity is measured or a quality attribute is assessed. As a subclass of sosa:Procedure (which is lis:InformationObject in the ido-ssn integration), Measurement is an information object — a specification of how to measure — rather than a physical thing or activity. Its actual-layer counterpart is expressed via sosa:Observation instances that reference this procedure through sosa:usedProcedure. Domain-specific ontologies can define specific measurement procedures such as gauge calibration protocols, CMM inspection programs, or SPC sampling procedures."@en ;
                 rdfs:label "Measurement"@en .


###  https://w3id.org/mqto#Method
mqto:Method rdf:type owl:Class ;
            rdfs:subClassOf lis:Activity ,
                            mqto:IshikawaItem ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty lis:activityPartOf ;
                              owl:allValuesFrom mqto:Method
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty lis:hasActivityPart ;
                              owl:allValuesFrom mqto:Method
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty lis:hasParticipant ;
                              owl:allValuesFrom [ rdf:type owl:Class ;
                                                  owl:unionOf ( mqto:Machine
                                                                mqto:Manpower
                                                                mqto:Material
                                                              )
                                                ]
                            ] ;
            rdfs:comment "A manufacturing process or procedure (the 'M' in Ishikawa's Method). Represents the specified activities and steps in manufacturing. This includes operations and procedures specific to the manufacturing domain. Methods can be decomposed into sub-methods and have Machines, Materials, and Manpower as participants."@en ;
            rdfs:label "Method"@en .


###  https://w3id.org/mqto#Metric
mqto:Metric rdf:type owl:Class ;
            rdfs:subClassOf lis:Specified ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty mqto:metricBelongsTo ;
                              owl:allValuesFrom mqto:IshikawaItem
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty mqto:metricReferredBy ;
                              owl:allValuesFrom mqto:FailureMode
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty mqto:readsFrom ;
                              owl:allValuesFrom mqto:Signal
                            ] ;
            rdfs:comment "A specified calculation or key performance indicator (KPI) that bridges quantitative sensor data and qualitative failure detection. Reads from one or more Signals, applies an assessment method over a time window, and compares results against threshold bounds to detect anomalies. Belongs to an IshikawaItem and is referred to by Failure Modes. The actual-layer counterpart is MetricAssessment."@en ;
            rdfs:label "Metric"@en .


###  https://w3id.org/mqto#MetricAssessment
mqto:MetricAssessment rdf:type owl:Class ;
                      rdfs:subClassOf lis:Actual ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty lis:implements ;
                                        owl:someValuesFrom mqto:Metric
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty mqto:calculatedFor ;
                                        owl:someValuesFrom mqto:ActualIshikawaItem
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty mqto:basedOn ;
                                        owl:allValuesFrom mqto:Observation
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty mqto:evaluatesProperty ;
                                        owl:allValuesFrom mqto:ObservableProperty
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty mqto:raised ;
                                        owl:allValuesFrom mqto:FailureOccurrence
                                      ] ;
                      rdfs:comment "An instance-layer evaluation that implements a Metric specification by computing a value from actual Observations and comparing it against threshold bounds. Calculated for an ActualIshikawaItem at a specific time, based on observations within a time window. Produces both a calculatedValue (quantitative result) and assessmentValue (boolean pass/fail). When threshold violations are detected, raises FailureOccurrences."@en ;
                      rdfs:label "Metric Assessment"@en ;
                      <http://www.w3.org/2004/02/skos/core#example> """ex:MA_001  a mqto:MetricAssessment ;
    lis:implements       ex:TemperatureMetric ;
    mqto:calculatedFor   ex:Machine4115 ;
    mqto:calculatedValue 718.3 ;
    mqto:assessmentValue true ;
    mqto:calculatedTime  \"2026-04-14T08:15:00\"^^xsd:dateTime .
    # calculatedValue was read from Result.ex:temperature via resultProperty"""@en .


###  https://w3id.org/mqto#ObservableProperty
mqto:ObservableProperty rdf:type owl:Class ;
                        rdfs:subClassOf sosa:ObservableProperty ,
                                        mqto:Property ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty ssn:isPropertyOf ;
                                          owl:allValuesFrom mqto:ActualIshikawaItem
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty mqto:evaluatedBy ;
                                          owl:allValuesFrom mqto:MetricAssessment
                                        ] ;
                        rdfs:comment "An observable property of an ActualIshikawaItem that can be measured via Observations. As a subclass of mqto:Property, it implements a Signal specification from the specified layer, establishing traceability from actual observations back to the specified data channel definition. Note: subclassing both sosa:ObservableProperty (an abstract quality type) and lis:Actual (via mqto:Property, a concrete instance) reflects the modelling choice that each mqto:ObservableProperty individual represents a specific, concrete observable quality tied to a particular actual item — not a reusable abstract type. This parallels how sosa:ObservableProperty instances are used in practice (e.g. 'the temperature of this specific machine part') rather than as universal property types."@en ;
                        rdfs:label "Observable Property"@en .


###  https://w3id.org/mqto#Observation
mqto:Observation rdf:type owl:Class ;
                 rdfs:subClassOf sosa:Observation ;
                 rdfs:comment "Subclass of sosa:Observation, representing a single sensor reading or measurement event. Links to an ActualIshikawaItem (feature of interest), an ObservableProperty (what is being measured), and a Result (the measured value). Observations capture time-series data from PLCs, sensors, and SCADA systems including temperature readings, pressure measurements, and cycle times."@en ;
                 rdfs:label "Observation"@en .


###  https://w3id.org/mqto#PhysicalMachine
mqto:PhysicalMachine rdf:type owl:Class ;
                     rdfs:subClassOf lis:PhysicalArtefact ,
                                     mqto:ActualIshikawaItem ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty lis:implements ;
                                       owl:someValuesFrom mqto:Machine
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty lis:participantIn ;
                                       owl:allValuesFrom mqto:ProcessExecution
                                     ] ;
                     rdfs:comment "Actual machine instance, the instance-layer counterpart of Machine. Represents specific physical equipment with serial numbers, operational history, and sensor data. Examples include specific manufacturing equipment with serial numbers, furnaces, and robots with concrete observation data."@en ;
                     rdfs:label "Physical Machine"@en .


###  https://w3id.org/mqto#PhysicalMaterial
mqto:PhysicalMaterial rdf:type owl:Class ;
                      rdfs:subClassOf lis:PhysicalArtefact ,
                                      mqto:ActualIshikawaItem ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty lis:implements ;
                                        owl:someValuesFrom mqto:Material
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty lis:participantIn ;
                                        owl:allValuesFrom mqto:ProcessExecution
                                      ] ;
                      rdfs:comment "Actual material instance, the instance-layer counterpart of Material. Represents specific batches, lots, or quantities of material with identifiers, composition data, and quality measurements. Examples include specific material batches with batch numbers, chemical composition, and quality measurements."@en ;
                      rdfs:label "Physical Material"@en .


###  https://w3id.org/mqto#ProcessExecution
mqto:ProcessExecution rdf:type owl:Class ;
                      rdfs:subClassOf mqto:ActualIshikawaItem ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty lis:implements ;
                                        owl:someValuesFrom mqto:Method
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty lis:hasParticipant ;
                                        owl:allValuesFrom [ rdf:type owl:Class ;
                                                            owl:unionOf ( mqto:PhysicalMachine
                                                                          mqto:PhysicalMaterial
                                                                        )
                                                          ]
                                      ] ;
                      rdfs:comment "Actual execution of a Method, the instance-layer counterpart of Method. Links to concrete PhysicalMachines and PhysicalMaterials as participants. This represents actual production operations with specific machines, material batches, timestamps, and observation data. Note: ProcessExecution does not subclass lis:Activity (lis:Temporal) because it subclasses ActualIshikawaItem, which inherits sosa:FeatureOfInterest (lis:Object). In LIS, lis:Temporal and lis:Object are disjoint top-level categories, so both superclasses together would make the class unsatisfiable. The temporal character of a process execution is expressed instead through mqto:startTime / mqto:endTime properties and the sosa:Observations for which it serves as feature of interest."@en ;
                      rdfs:label "Process Execution"@en .


###  https://w3id.org/mqto#Property
mqto:Property rdf:type owl:Class ;
              rdfs:subClassOf lis:Actual ,
                              ssn:Property ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty lis:implements ;
                                owl:someValuesFrom mqto:Signal
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty ssn:isPropertyOf ;
                                owl:allValuesFrom mqto:ActualIshikawaItem
                              ] ;
              rdfs:comment "Actual-layer counterpart of Signal. Represents a property (observable or actuable) of an ActualIshikawaItem that implements a Signal specification from the specified layer. While Signal defines the data channel metadata (identifier, unit, sampling rate, direction), Property represents the actual measured or actuated quality of a specific feature of interest. This class serves as the abstract superclass for both ObservableProperty (for sensing/measurement) and ActuableProperty (for actuation/control)."@en ;
              rdfs:label "Property"@en .


###  https://w3id.org/mqto#Result
mqto:Result rdf:type owl:Class ;
            rdfs:subClassOf sosa:Result ;
            rdfs:comment "The outcome of an Observation, containing the measured value (via measValue or other result properties). Subclass of sosa:Result. MetricAssessments extract result values from these Result instances using the resultProperty meta-property to specify which data property should be read."@en ;
            rdfs:label "Result"@en ;
            <http://www.w3.org/2004/02/skos/core#example> """A die-casting shot produces one Result per PLC cycle carrying multiple process values:
  ex:Result_Shot042  a mqto:Result ;
      ex:temperature   718.3 ;
      ex:pressure      980.0 ;
      ex:cycleTime      24.7 ."""@en .


###  https://w3id.org/mqto#Signal
mqto:Signal rdf:type owl:Class ;
            rdfs:subClassOf lis:Specified ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty mqto:readBy ;
                              owl:allValuesFrom mqto:Metric
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty mqto:signalProvidedBy ;
                              owl:allValuesFrom mqto:IshikawaItem
                            ] ;
            rdfs:comment "A specified data channel in the electrical-engineering sense: a named, typed signal such as a PLC variable, an analog voltage line, a fieldbus message, or a time-series data stream. A Signal may carry measurement data (sensor/output signals), control data (actuator/input signals), or both simultaneously — a setpoint, for instance, is written as a command to an actuator and can equally be read back as an observable value. It describes the metadata of the channel (identifier, unit, sampling rate, direction, etc.) rather than any particular observation or sensor device. It sits in the specified layer as the concrete data-source or data-sink binding for an abstract Metric, and is thereby distinct from sosa:ObservableProperty (which characterises an observable quality of a feature of interest in the actual layer) and from sosa:Sensor (which is the physical observing device)."@en ;
            rdfs:label "Signal"@en .


