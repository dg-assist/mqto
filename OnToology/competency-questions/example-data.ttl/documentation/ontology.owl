    <!-- https://w3id.org/mqto/example#Act001 -->


    <NamedIndividual rdf:about="https://w3id.org/mqto/example#Act001">
        <rdf:type rdf:resource="http://www.w3.org/ns/sosa/Actuation"/>
        <rdf:type rdf:resource="https://w3id.org/mqto#Actuation"/>
        <sosa:actsOnProperty rdf:resource="https://w3id.org/mqto/example#Machine4115_FurnaceSetpoint"/>
        <sosa:hasFeatureOfInterest rdf:resource="https://w3id.org/mqto/example#Machine4115"/>
        <sosa:hasResult rdf:resource="https://w3id.org/mqto/example#Result_Act001"/>
