        <sosa:resultTime rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-03-15T10:50:00</sosa:resultTime>
    </NamedIndividual>
    


    <!-- https://w3id.org/mqto/example#AdjustFurnaceSetpoint -->


    <NamedIndividual rdf:about="https://w3id.org/mqto/example#AdjustFurnaceSetpoint">
        <rdf:type rdf:resource="https://w3id.org/mqto#CountermeasureStep"/>
        <rdfs:label xml:lang="en">Adjust furnace setpoint</rdfs:label>
    </NamedIndividual>
    


    <!-- https://w3id.org/mqto/example#AdjustMeltTemp -->


    <NamedIndividual rdf:about="https://w3id.org/mqto/example#AdjustMeltTemp">
        <rdf:type rdf:resource="https://w3id.org/mqto#Countermeasure"/>
        <rdl:hasParticipant rdf:resource="https://w3id.org/mqto/example#DieCastingCell"/>
        <rdfs:label xml:lang="en">Adjust melt holding temperature to alloy specification</rdfs:label>
        <mqto:hasStepList rdf:resource="https://w3id.org/mqto/example#AdjustMeltTemp_List1"/>
        <mqto:mitigates rdf:resource="https://w3id.org/mqto/example#MeltTempTooHigh"/>
        <mqto:mitigates rdf:resource="https://w3id.org/mqto/example#Porosity"/>
        <mqto:weight rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">90</mqto:weight>
    </NamedIndividual>
    


    <!-- https://w3id.org/mqto/example#AdjustMeltTemp_List1 -->


    <NamedIndividual rdf:about="https://w3id.org/mqto/example#AdjustMeltTemp_List1">
        <rdf:type rdf:resource="https://w3id.org/mqto#CountermeasureStepList"/>
        <mqto:first rdf:resource="https://w3id.org/mqto/example#CheckCurrentTemp"/>
        <mqto:rest rdf:resource="https://w3id.org/mqto/example#AdjustMeltTemp_List2"/>
    </NamedIndividual>
    


    <!-- https://w3id.org/mqto/example#AdjustMeltTemp_List2 -->


    <NamedIndividual rdf:about="https://w3id.org/mqto/example#AdjustMeltTemp_List2">
        <rdf:type rdf:resource="https://w3id.org/mqto#CountermeasureStepList"/>
        <mqto:first rdf:resource="https://w3id.org/mqto/example#AdjustFurnaceSetpoint"/>
        <mqto:rest rdf:resource="https://w3id.org/mqto/example#AdjustMeltTemp_List3"/>
    </NamedIndividual>
    


    <!-- https://w3id.org/mqto/example#AdjustMeltTemp_List3 -->


    <NamedIndividual rdf:about="https://w3id.org/mqto/example#AdjustMeltTemp_List3">
        <rdf:type rdf:resource="https://w3id.org/mqto#CountermeasureStepList"/>
        <mqto:first rdf:resource="https://w3id.org/mqto/example#VerifyNewTemp"/>
        <mqto:rest rdf:resource="https://w3id.org/mqto#nil"/>
