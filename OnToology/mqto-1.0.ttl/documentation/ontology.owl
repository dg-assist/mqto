        <rdfs:comment xml:lang="en">A manufacturing process or procedure. Represents specified activities and operations that can be decomposed into sub-methods.</rdfs:comment>
        <rdfs:label xml:lang="en">Method</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#MethodExecution -->


