    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/abstract -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/abstract"/>
    


    <!-- http://purl.org/dc/terms/created -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/created"/>
    


    <!-- http://purl.org/dc/terms/subject -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/subject"/>
    


    <!-- http://purl.org/ontology/bibo/status -->


    <owl:AnnotationProperty rdf:about="http://purl.org/ontology/bibo/status"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespacePrefix -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespacePrefix"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespaceUri -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespaceUri"/>
    


    <!-- http://schema.org/codeRepository -->


    <owl:AnnotationProperty rdf:about="http://schema.org/codeRepository"/>
    


    <!-- http://schema.org/funding -->


    <owl:AnnotationProperty rdf:about="http://schema.org/funding"/>
    


    <!-- http://schema.org/logo -->


    <owl:AnnotationProperty rdf:about="http://schema.org/logo"/>
    


    <!-- http://xmlns.com/foaf/0.1/homepage -->


    <owl:AnnotationProperty rdf:about="http://xmlns.com/foaf/0.1/homepage"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://w3id.org/mqto#appearedOn -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#appearedOn">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#FailureOccurrence"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#ActualIshikawaItem"/>
        <rdfs:label xml:lang="en">appeared on</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#baseFor -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#baseFor">
        <owl:inverseOf rdf:resource="https://w3id.org/mqto#basedOn"/>
        <rdfs:label xml:lang="en">base for</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#basedOn -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#basedOn">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#MetricAssessment"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#Observation"/>
        <rdfs:label xml:lang="en">based on</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#calculatedFor -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#calculatedFor">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#MetricAssessment"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#ActualIshikawaItem"/>
        <rdfs:label xml:lang="en">calculated for</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#causedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#causedBy">
        <owl:inverseOf rdf:resource="https://w3id.org/mqto#causes"/>
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Failure"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#Failure"/>
        <rdfs:label xml:lang="en">caused by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#causedByModerately -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#causedByModerately">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/mqto#causedBy"/>
        <owl:inverseOf rdf:resource="https://w3id.org/mqto#causesModerately"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#causedByStrongly -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#causedByStrongly">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/mqto#causedBy"/>
        <owl:inverseOf rdf:resource="https://w3id.org/mqto#causesStrongly"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#causedByWeakly -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#causedByWeakly">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/mqto#causedBy"/>
        <owl:inverseOf rdf:resource="https://w3id.org/mqto#causesWeakly"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#causes -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#causes">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Failure"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#Failure"/>
        <rdfs:label xml:lang="en">causes</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#causesModerately -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#causesModerately">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/mqto#causes"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#causesStrongly -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#causesStrongly">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/mqto#causes"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#causesWeakly -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#causesWeakly">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/mqto#causes"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#evaluatedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#evaluatedBy">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#ObservableProperty"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#MetricAssessment"/>
        <rdfs:comment xml:lang="en">Relates an ObservableProperty to the MetricAssessment that evaluated it (actual layer). Inverse of mqto:evaluatesProperty. Counterpart to mqto:readBy in the specified layer.</rdfs:comment>
        <rdfs:label xml:lang="en">evaluated by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#evaluatesProperty -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#evaluatesProperty">
        <owl:inverseOf rdf:resource="https://w3id.org/mqto#evaluatedBy"/>
        <rdfs:domain rdf:resource="https://w3id.org/mqto#MetricAssessment"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#ObservableProperty"/>
        <rdfs:comment xml:lang="en">Relates a MetricAssessment to the ObservableProperty it evaluated (actual layer). Counterpart to mqto:readsFrom, which relates a Metric to a Signal in the specified layer.</rdfs:comment>
        <rdfs:label xml:lang="en">evaluates property</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#failureBelongsTo -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#failureBelongsTo">
        <owl:inverseOf rdf:resource="https://w3id.org/mqto#hasFailure"/>
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Failure"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#IshikawaItem"/>
        <rdfs:label xml:lang="en">failure belongs to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#first -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#first">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#List"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#CountermeasureStep"/>
        <rdfs:comment xml:lang="en">Points to the first CountermeasureStep in a reusable ordered list. Analogous to rdf:first but defined as an explicit OWL object property with proper domain/range constraints. The list structure (rather than a direct step-to-step chain) allows the same CountermeasureStep instance to appear in multiple Countermeasure procedures without embedding order into the step itself.</rdfs:comment>
        <rdfs:label xml:lang="en">first</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#hasFailure -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#hasFailure">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#IshikawaItem"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#Failure"/>
        <rdfs:label xml:lang="en">has failure</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#hasFirstStep -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#hasFirstStep">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/mqto#hasStep"/>
        <rdfs:domain rdf:resource="https://w3id.org/mqto#CountermeasureExecution"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#CountermeasureStepExecution"/>
        <rdfs:comment xml:lang="en">Points to the first CountermeasureStepExecution in the concrete execution chain. In the actual layer, steps are performed in a fixed linear order and are not reused, so the order is encoded directly in the chain via mqto:hasNextStep.</rdfs:comment>
        <rdfs:label xml:lang="en">has first step</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#hasMetric -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#hasMetric">
        <owl:inverseOf rdf:resource="https://w3id.org/mqto#metricBelongsTo"/>
        <rdfs:domain rdf:resource="https://w3id.org/mqto#IshikawaItem"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#Metric"/>
        <rdfs:label xml:lang="en">has metric</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#hasNextStep -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#hasNextStep">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/mqto#hasStep"/>
        <rdfs:domain rdf:resource="https://w3id.org/mqto#CountermeasureStepExecution"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#CountermeasureStepExecution"/>
        <rdfs:comment xml:lang="en">Links one CountermeasureStepExecution to the next in the concrete execution sequence. Unlike the specified layer (which uses mqto:List for reusability), the actual execution occurs once in a specific order, so step-to-step chaining is appropriate here.</rdfs:comment>
        <rdfs:label xml:lang="en">has next step</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#hasStep -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#hasStep">
        <rdfs:subPropertyOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/hasActivityPart"/>
        <rdfs:domain rdf:resource="https://w3id.org/mqto#CountermeasureExecution"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#CountermeasureStepExecution"/>
        <rdfs:label xml:lang="en">has step</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#metricBelongsTo -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#metricBelongsTo">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Metric"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#IshikawaItem"/>
        <rdfs:label xml:lang="en">metric belongs to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#metricReferredBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#metricReferredBy">
        <owl:inverseOf rdf:resource="https://w3id.org/mqto#refersToMetric"/>
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Metric"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#Failure"/>
        <rdfs:label xml:lang="en">metric referred by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#mitigated -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#mitigated">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#CountermeasureExecution"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#FailureOccurrence"/>
        <rdfs:comment xml:lang="en">A countermeasure execution mitigated a failure occurrence. Note: this is the actual-layer forward property (past participle). The specified-layer equivalent uses mqto:mitigates (active voice). The naming difference is intentional: &apos;mitigated&apos; records a completed fact at instance level, while &apos;mitigates&apos; expresses a general capability at schema level.</rdfs:comment>
        <rdfs:label xml:lang="en">mitigated</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#mitigatedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#mitigatedBy">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Failure"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#Countermeasure"/>
        <rdfs:label xml:lang="en">mitigated by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#mitigates -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#mitigates">
        <owl:inverseOf rdf:resource="https://w3id.org/mqto#mitigatedBy"/>
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Countermeasure"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#Failure"/>
        <rdfs:label xml:lang="en">mitigates</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#providesSignal -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#providesSignal">
        <owl:inverseOf rdf:resource="https://w3id.org/mqto#signalProvidedBy"/>
        <rdfs:domain rdf:resource="https://w3id.org/mqto#IshikawaItem"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#Signal"/>
        <rdfs:comment xml:lang="en">Relates an IshikawaItem (Machine, Material, or Method) to the data channels (Signals) associated with it. A Signal may be an output channel carrying measurement data from the item (e.g. a temperature sensor reading) or an input channel carrying control data to the item (e.g. a setpoint or actuator command). The Signal is a specified channel descriptor; actual observations are made via sosa:Observation on the corresponding ActualIshikawaItem.</rdfs:comment>
        <rdfs:label xml:lang="en">provides signal</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#raised -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#raised">
        <owl:inverseOf rdf:resource="https://w3id.org/mqto#raisedBy"/>
        <rdfs:domain rdf:resource="https://w3id.org/mqto#MetricAssessment"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#FailureOccurrence"/>
        <rdfs:label xml:lang="en">raised</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#raisedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#raisedBy">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#FailureOccurrence"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#MetricAssessment"/>
        <rdfs:label xml:lang="en">raised by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#readBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#readBy">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Signal"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#Metric"/>
        <rdfs:comment xml:lang="en">Relates a Signal (data channel) to the Metric that is computed from it (specified layer). Inverse of mqto:readsFrom. For the actual-layer counterpart see mqto:evaluatedBy.</rdfs:comment>
        <rdfs:label xml:lang="en">read by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#readsFrom -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#readsFrom">
        <owl:inverseOf rdf:resource="https://w3id.org/mqto#readBy"/>
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Metric"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#Signal"/>
        <rdfs:comment xml:lang="en">Relates a Metric to the Signal (data channel) it is computed from (specified layer). Inverse of mqto:readBy. For the actual-layer counterpart see mqto:evaluatesProperty.</rdfs:comment>
        <rdfs:label xml:lang="en">reads from</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#refersToMetric -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#refersToMetric">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Failure"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#Metric"/>
        <rdfs:label xml:lang="en">refers to metric</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#rest -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#rest">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#List"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#List"/>
        <rdfs:comment xml:lang="en">Points to the remainder of the ordered step list. Analogous to rdf:rest but defined as an explicit OWL object property with proper domain/range constraints for better reasoner compatibility. Together with mqto:first, this implements a reusable linked-list container so that step order is encoded in the list, not in the steps themselves. The list must terminate at mqto:nil; circular references are not permitted, though OWL cannot formally enforce acyclicity.</rdfs:comment>
        <rdfs:label xml:lang="en">rest</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#resultProperty -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#resultProperty">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Metric"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
        <rdfs:comment xml:lang="en">Meta-property that specifies which data property of sosa:Result instances should be extracted and used as input for this Metric&apos;s calculation. For example, a Metric&apos;s resultProperty can point to a specific data property of the Result to extract that field from each Result instance within the specified time window. This enables multiple metrics to derive different calculations from the same observation results by selecting different result attributes. Note: This is a meta-level construct (an object property pointing to data properties), which while not ideal OWL modeling practice, provides a simple declarative mechanism for metrics to specify their input data field without requiring complex extraction rules or SPARQL property paths.</rdfs:comment>
        <rdfs:label xml:lang="en">result property</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#signalProvidedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#signalProvidedBy">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Signal"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#IshikawaItem"/>
        <rdfs:label xml:lang="en">signal provided by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#steps -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#steps">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Countermeasure"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#List"/>
        <rdfs:comment xml:lang="en">Links a Countermeasure to its ordered list of steps. The indirection via mqto:List enables the same CountermeasureStep to be referenced in multiple Countermeasure definitions (reuse across procedures).</rdfs:comment>
        <rdfs:label xml:lang="en">steps</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#suggested -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#suggested">
        <owl:inverseOf rdf:resource="https://w3id.org/mqto#suggestedBy"/>
        <rdfs:domain rdf:resource="https://w3id.org/mqto#FailureOccurrence"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#CountermeasureExecution"/>
        <rdfs:comment xml:lang="en">A failure occurrence suggested a countermeasure execution.</rdfs:comment>
        <rdfs:label xml:lang="en">suggested</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#suggestedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#suggestedBy">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#CountermeasureExecution"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#FailureOccurrence"/>
        <rdfs:comment xml:lang="en">A countermeasure execution was suggested by a failure occurrence.</rdfs:comment>
        <rdfs:label xml:lang="en">suggested by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/identifier -->


    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/identifier"/>
    


    <!-- https://w3id.org/mqto#abortedReason -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#abortedReason">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">aborted reason</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#abortedTime -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#abortedTime">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:label xml:lang="en">aborted time</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#assessmentValue -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#assessmentValue">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#MetricAssessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Boolean pass/fail decision resulting from comparing the calculatedValue against the Metric&apos;s threshold bounds (lowerBound/upperBound). True indicates a threshold violation (failure condition detected), false indicates normal operation within bounds.</rdfs:comment>
        <rdfs:label xml:lang="en">assessment value</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#calculatedTime -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#calculatedTime">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#MetricAssessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:label xml:lang="en">calculated time</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#calculatedValue -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#calculatedValue">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#MetricAssessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">The actual computed numeric value of the metric assessment. This preserves the quantitative result before threshold comparison, enabling trend analysis, statistical modeling, and root cause correlation. For example, if a temperature metric calculates 85.7°C and the upperBound is 80°C, calculatedValue is 85.7 while assessmentValue would be true (indicating a violation). The unit of measurement is inherited from the implemented Metric specification.</rdfs:comment>
        <rdfs:label xml:lang="en">calculated value</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#completionTime -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#completionTime">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#CountermeasureStepExecution"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:label xml:lang="en">completion time</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#endTime -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#endTime">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:label xml:lang="en">end time</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#identifier -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#identifier">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/identifier"/>
        <rdfs:label xml:lang="en">identifier</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#lowerBound -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#lowerBound">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Metric"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:label xml:lang="en">lower bound</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#markdownContent -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#markdownContent">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/mqto#Countermeasure"/>
                    <rdf:Description rdf:about="https://w3id.org/mqto#CountermeasureStep"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">markdown content</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#measValue -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#measValue">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Result"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label xml:lang="en">measurement value</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#method -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#method">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Metric"/>
        <rdfs:label xml:lang="en">method</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#reasoningLine -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#reasoningLine">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#CountermeasureExecution"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">reasoning line</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#role -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#role">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#CountermeasureStep"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">role</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#score -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#score">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#CountermeasureExecution"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:label xml:lang="en">score</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#startTime -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#startTime">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:label xml:lang="en">start time</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#timeWindowSize -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#timeWindowSize">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Metric"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:label xml:lang="en">time window size</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#upperBound -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#upperBound">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Metric"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:label xml:lang="en">upper bound</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#viewTime -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#viewTime">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#FailureOccurrence"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:label xml:lang="en">view time</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#weight -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#weight">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/mqto#Countermeasure"/>
                    <rdf:Description rdf:about="https://w3id.org/mqto#Failure"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:label xml:lang="en">weight</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/net/p-plan#Step -->


    <owl:Class rdf:about="http://purl.org/net/p-plan#Step"/>
    


    <!-- http://www.w3.org/1999/02/22-rdf-syntax-ns#Property -->


    <owl:Class rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    


    <!-- http://www.w3.org/ns/sosa/ActuableProperty -->


    <owl:Class rdf:about="http://www.w3.org/ns/sosa/ActuableProperty"/>
    


    <!-- http://xmlns.com/foaf/0.1/Person -->


    <owl:Class rdf:about="http://xmlns.com/foaf/0.1/Person"/>
    


    <!-- https://w3id.org/mqto#ActuableProperty -->


    <owl:Class rdf:about="https://w3id.org/mqto#ActuableProperty">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/ActuableProperty"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/mqto#Property"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/ns/ssn/isPropertyOf"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#ActualIshikawaItem"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An actuable property of an ActualIshikawaItem that can be controlled or modified via Actuations. As a subclass of mqto:Property, it implements a Signal specification from the specified layer. Represents properties that can be set or modified, such as setpoints, valve positions, motor speeds, or control commands. The Signal in the specified layer defines the control channel metadata, while ActuableProperty represents the actual controllable quality of a specific feature of interest.</rdfs:comment>
        <rdfs:label xml:lang="en">Actuable Property</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#ActualIshikawaItem -->


    <owl:Class rdf:about="https://w3id.org/mqto#ActualIshikawaItem">
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/Actual"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/FeatureOfInterest"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/ns/sosa/isFeatureOfInterestOf"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#Observation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/ns/ssn/hasProperty"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#ObservableProperty"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Abstract superclass for actual/instance layer counterparts of IshikawaItem. Integrates SOSA: each ActualIshikawaItem is a FeatureOfInterest that can be observed, has ObservableProperties, and can have FailureOccurrences. Concrete instances include specific machines, material batches, and production runs.</rdfs:comment>
        <rdfs:label xml:lang="en">Actual Ishikawa Item</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#Countermeasure -->


    <owl:Class rdf:about="https://w3id.org/mqto#Countermeasure">
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/Activity"/>
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/Specified"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pko#Procedure"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#steps"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/mqto#List"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/hasParticipant"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/mqto#Machine"/>
                            <rdf:Description rdf:about="https://w3id.org/mqto#Material"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#mitigates"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#Failure"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A remediation procedure that mitigates one or more Failures. Countermeasures are structured as ordered sequences of CountermeasureSteps, represented via the mqto:List pattern for reusability. As a subclass of pko:Procedure, countermeasures align with the Procedural Knowledge Ontology&apos;s procedure modeling patterns while maintaining integration with the LIS specified/actual architecture.</rdfs:comment>
        <rdfs:label xml:lang="en">Countermeasure</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#CountermeasureExecution -->


    <owl:Class rdf:about="https://w3id.org/mqto#CountermeasureExecution">
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/Actual"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pko#ProcedureExecution"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/implements"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/mqto#Countermeasure"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/hasParticipant"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/mqto#MaterialChunk"/>
                            <rdf:Description rdf:about="https://w3id.org/mqto#PhysicalMachine"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#hasStep"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#CountermeasureStepExecution"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#mitigated"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#FailureOccurrence"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#suggestedBy"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#FailureOccurrence"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">The actual execution of a Countermeasure procedure, performed to mitigate one or more FailureOccurrences. Links to the Countermeasure specification via lis:implements (LIS pattern) and tracks which specific failures were addressed. As a subclass of pko:ProcedureExecution, countermeasure executions align with PKO&apos;s procedure execution model while maintaining LIS actual/specified semantics. Note: Does not directly subclass lis:Activity (which is lis:Specified), but implements Countermeasure (which is lis:Activity), maintaining the LIS distinction between specified and actual layers.</rdfs:comment>
        <rdfs:label xml:lang="en">Countermeasure Execution</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#CountermeasureStep -->


    <owl:Class rdf:about="https://w3id.org/mqto#CountermeasureStep">
        <rdfs:subClassOf rdf:resource="http://purl.org/net/p-plan#Step"/>
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/Activity"/>
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/Specified"/>
        <rdfs:comment xml:lang="en">A reusable specification of a single step within a Countermeasure procedure. Because the same step (e.g. &apos;clean the mould&apos;) may occur in multiple Countermeasures, ordering is not encoded in the step itself but in the mqto:List that references it. As a subclass of p-plan:Step, countermeasure steps align with the P-PLAN ontology for plan-based activity modeling.</rdfs:comment>
        <rdfs:label xml:lang="en">Countermeasure Step</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#CountermeasureStepExecution -->


    <owl:Class rdf:about="https://w3id.org/mqto#CountermeasureStepExecution">
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/Actual"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pko#StepExecution"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/implements"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/mqto#CountermeasureStep"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">The actual, single execution of one CountermeasureStep. Each execution implements a specific CountermeasureStep from the specified layer via lis:implements, performed in a concrete, non-reused linear order encoded via mqto:hasFirstStep / mqto:hasNextStep, contrasting with the specified layer where mqto:List enables step reuse across procedures. As a subclass of pko:StepExecution, countermeasure step executions align with PKO&apos;s step execution model. Note: Does not directly subclass lis:Activity (which is lis:Specified), but implements CountermeasureStep (which is lis:Activity), maintaining the LIS distinction between specified and actual layers.</rdfs:comment>
        <rdfs:label xml:lang="en">Countermeasure Step Execution</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#Failure -->


    <owl:Class rdf:about="https://w3id.org/mqto#Failure">
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/Specified"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#failureBelongsTo"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/mqto#IshikawaItem"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#causedBy"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#Failure"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#causes"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#Failure"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#failureBelongsTo"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#IshikawaItem"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#mitigatedBy"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#Countermeasure"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#refersToMetric"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#Metric"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Failure</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#FailureOccurrence -->


    <owl:Class rdf:about="https://w3id.org/mqto#FailureOccurrence">
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/Actual"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/implements"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/mqto#Failure"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#appearedOn"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/mqto#ActualIshikawaItem"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#mitigatedBy"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#CountermeasureExecution"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#raisedBy"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#MetricAssessment"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Failure Occurrence</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#IshikawaItem -->


    <owl:Class rdf:about="https://w3id.org/mqto#IshikawaItem">
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/Specified"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#hasFailure"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#Failure"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#hasMetric"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#Metric"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#providesSignal"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#Signal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Abstract superclass for the three categories of root causes in an Ishikawa (fishbone) diagram: Machine, Material, and Method. Domain-specific ontologies can specialize these concepts for their manufacturing domain.</rdfs:comment>
        <rdfs:label xml:lang="en">Ishikawa Item</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#List -->


    <owl:Class rdf:about="https://w3id.org/mqto#List">
        <rdfs:comment xml:lang="en">An ordered, reusable container of CountermeasureSteps within the specified layer. Implements an OWL-native linked list pattern (mqto:first / mqto:rest) inspired by RDF Collections, but using explicit OWL class and property definitions for better reasoner compatibility. Standard rdf:List creates known issues with OWL reasoners due to blank node handling and recursive structure reasoning. This approach ensures compatibility with standard reasoners such as HermiT and Pellet while maintaining the core benefit: step order is external to the step instances, allowing steps to be shared across different Countermeasure procedures without embedding ordering information in the steps themselves. The list is terminated by mqto:nil. See OWL 2 Primer Section 4.2 on structural specification limitations with blank nodes.</rdfs:comment>
        <rdfs:label xml:lang="en">List</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://www.w3.org/TR/owl2-primer/"/>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#Machine -->


    <owl:Class rdf:about="https://w3id.org/mqto#Machine">
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/PhysicalArtefact"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/mqto#IshikawaItem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/participantIn"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#Method"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Manufacturing equipment, tools, and devices (the &apos;M&apos; in Ishikawa&apos;s Machine). Represents specified physical resources that participate in Methods. Domain-specific ontologies can define specific machine types such as cells, furnaces, and robots. Machines provide Signals (sensor readings, control channels) and can have associated Failures and Metrics.</rdfs:comment>
        <rdfs:label xml:lang="en">Machine</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#Material -->


    <owl:Class rdf:about="https://w3id.org/mqto#Material">
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/Compound"/>
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/PhysicalArtefact"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/mqto#IshikawaItem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/participantIn"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#Method"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Raw materials, consumables, and inputs to manufacturing (the &apos;M&apos; in Ishikawa&apos;s Material). Represents specified material types that participate in Methods. Domain-specific ontologies can define specific material types such as alloys, lubricants, and consumables. Materials can have properties monitored via Signals and associated quality Metrics.</rdfs:comment>
        <rdfs:label xml:lang="en">Material</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#MaterialChunk -->


    <owl:Class rdf:about="https://w3id.org/mqto#MaterialChunk">
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/Compound"/>
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/PhysicalArtefact"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/mqto#ActualIshikawaItem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/participantIn"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#ProcessExecution"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Actual material instance, the instance-layer counterpart of Material. Represents specific batches, lots, or quantities of material with identifiers, composition data, and quality measurements. Examples include specific material batches with batch numbers, chemical composition, and quality measurements.</rdfs:comment>
        <rdfs:label xml:lang="en">Material Chunk</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#Method -->


    <owl:Class rdf:about="https://w3id.org/mqto#Method">
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/Activity"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/mqto#IshikawaItem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/activityPartOf"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#Method"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/hasActivityPart"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#Method"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/hasParticipant"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/mqto#Machine"/>
                            <rdf:Description rdf:about="https://w3id.org/mqto#Material"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A manufacturing process or procedure (the &apos;M&apos; in Ishikawa&apos;s Method). Represents the specified activities and steps in manufacturing. This includes operations and procedures specific to the manufacturing domain. Methods can be decomposed into sub-methods and have Machines and Materials as participants.</rdfs:comment>
        <rdfs:label xml:lang="en">Method</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#Metric -->


    <owl:Class rdf:about="https://w3id.org/mqto#Metric">
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/Specified"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#metricBelongsTo"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#IshikawaItem"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#metricReferredBy"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#Failure"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#readsFrom"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#Signal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Metric</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#MetricAssessment -->


    <owl:Class rdf:about="https://w3id.org/mqto#MetricAssessment">
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/Actual"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/implements"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/mqto#Metric"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#calculatedFor"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/mqto#ActualIshikawaItem"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#basedOn"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#Observation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#evaluatesProperty"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#ObservableProperty"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#raised"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#FailureOccurrence"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Metric Assessment</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#ObservableProperty -->


    <owl:Class rdf:about="https://w3id.org/mqto#ObservableProperty">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/ObservableProperty"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/mqto#Property"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/ns/ssn/isPropertyOf"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#ActualIshikawaItem"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#evaluatedBy"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#MetricAssessment"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An observable property of an ActualIshikawaItem that can be measured via Observations. As a subclass of mqto:Property, it implements a Signal specification from the specified layer, establishing traceability from actual observations back to the specified data channel definition. Note: subclassing both sosa:ObservableProperty (an abstract quality type) and lis:Actual (via mqto:Property, a concrete instance) reflects the modelling choice that each mqto:ObservableProperty individual represents a specific, concrete observable quality tied to a particular actual item — not a reusable abstract type. This parallels how sosa:ObservableProperty instances are used in practice (e.g. &apos;the temperature of this specific machine part&apos;) rather than as universal property types.</rdfs:comment>
        <rdfs:label xml:lang="en">Observable Property</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#Observation -->


    <owl:Class rdf:about="https://w3id.org/mqto#Observation">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:comment xml:lang="en">Subclass of sosa:Observation, representing a single sensor reading or measurement event. Links to an ActualIshikawaItem (feature of interest), an ObservableProperty (what is being measured), and a Result (the measured value). Observations capture time-series data from PLCs, sensors, and SCADA systems including temperature readings, pressure measurements, and cycle times.</rdfs:comment>
        <rdfs:label xml:lang="en">Observation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#PhysicalMachine -->


    <owl:Class rdf:about="https://w3id.org/mqto#PhysicalMachine">
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/PhysicalArtefact"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/mqto#ActualIshikawaItem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/participantIn"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#ProcessExecution"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Actual machine instance, the instance-layer counterpart of Machine. Represents specific physical equipment with serial numbers, operational history, and sensor data. Examples include specific manufacturing equipment with serial numbers, furnaces, and robots with concrete observation data.</rdfs:comment>
        <rdfs:label xml:lang="en">Physical Machine</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#ProcessExecution -->


    <owl:Class rdf:about="https://w3id.org/mqto#ProcessExecution">
        <rdfs:subClassOf rdf:resource="https://w3id.org/mqto#ActualIshikawaItem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/implements"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/mqto#Method"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/hasParticipant"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/mqto#MaterialChunk"/>
                            <rdf:Description rdf:about="https://w3id.org/mqto#PhysicalMachine"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Actual execution of a Method, the instance-layer counterpart of Method. Links to concrete PhysicalMachines and MaterialChunks as participants. This represents actual production operations with specific machines, material batches, timestamps, and observation data. Note: ProcessExecution does not directly subclass lis:Activity (which is lis:Specified), but instead subclasses ActualIshikawaItem (lis:Actual) and implements Method (which is lis:Activity). This maintains the LIS distinction between specified and actual layers.</rdfs:comment>
        <rdfs:label xml:lang="en">Process Execution</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#Property -->


    <owl:Class rdf:about="https://w3id.org/mqto#Property">
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/Actual"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/ssn/Property"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/implements"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/mqto#Signal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/ns/ssn/isPropertyOf"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#ActualIshikawaItem"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Actual-layer counterpart of Signal. Represents a property (observable or actuable) of an ActualIshikawaItem that implements a Signal specification from the specified layer. While Signal defines the data channel metadata (identifier, unit, sampling rate, direction), Property represents the actual measured or actuated quality of a specific feature of interest. This class serves as the abstract superclass for both ObservableProperty (for sensing/measurement) and ActuableProperty (for actuation/control).</rdfs:comment>
        <rdfs:label xml:lang="en">Property</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#Result -->


    <owl:Class rdf:about="https://w3id.org/mqto#Result">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Result"/>
        <rdfs:label xml:lang="en">Result</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#Signal -->


    <owl:Class rdf:about="https://w3id.org/mqto#Signal">
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/Specified"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#readBy"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#Metric"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#signalProvidedBy"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#IshikawaItem"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A specified data channel in the electrical-engineering sense: a named, typed signal such as a PLC variable, an analog voltage line, a fieldbus message, or a time-series data stream. A Signal may carry measurement data (sensor/output signals), control data (actuator/input signals), or both simultaneously — a setpoint, for instance, is written as a command to an actuator and can equally be read back as an observable value. It describes the metadata of the channel (identifier, unit, sampling rate, direction, etc.) rather than any particular observation or sensor device. It sits in the specified layer as the concrete data-source or data-sink binding for an abstract Metric, and is thereby distinct from sosa:ObservableProperty (which characterises an observable quality of a feature of interest in the actual layer) and from sosa:Sensor (which is the physical observing device).</rdfs:comment>
        <rdfs:label xml:lang="en">Signal</rdfs:label>
    </owl:Class>
    


