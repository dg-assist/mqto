            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#failureBelongsTo"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#FailureSourceCategory"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#mitigatedBy"/>
