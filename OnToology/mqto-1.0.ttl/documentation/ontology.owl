                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#Signal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Abstract superclass for root cause categories in an Ishikawa (fishbone) diagram. Has five concrete subclasses organizing failure causes by type.</rdfs:comment>
        <rdfs:label xml:lang="en">Failure Source Category</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#Machine -->


