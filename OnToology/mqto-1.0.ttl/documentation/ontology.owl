            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A specified calculation or KPI that bridges quantitative sensor data and qualitative failure detection. Applies an assessment method and compares results against threshold bounds. Actual-level counterpart: MetricAssessment.</rdfs:comment>
        <rdfs:label xml:lang="en">Metric</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#MetricAssessment -->


    <owl:Class rdf:about="https://w3id.org/mqto#MetricAssessment">
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/Actual"/>
