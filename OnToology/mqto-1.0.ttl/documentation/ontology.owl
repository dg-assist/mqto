            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Actual machine instance, the instance-level counterpart of Machine. Can be directly observed and have ssn:Properties.</rdfs:comment>
        <rdfs:label xml:lang="en">Physical Machine</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#PhysicalMaterial -->


    <owl:Class rdf:about="https://w3id.org/mqto#PhysicalMaterial">
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/PhysicalArtefact"/>
