            <owl:Restriction>
                <owl:onProperty rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/implements"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/mqto#Method"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Actual execution of a Method, the instance-level counterpart of Method. A concrete temporal manufacturing activity.</rdfs:comment>
        <rdfs:label xml:lang="en">Method Execution</rdfs:label>
