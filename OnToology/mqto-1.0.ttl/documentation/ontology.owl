<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/mqto#"
     xml:base="https://w3id.org/mqto"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:pav="http://purl.org/pav/"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:rdl="http://rds.posccaesar.org/ontology/lis14/rdl/"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:bibo="http://purl.org/ontology/bibo/"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:schema="http://schema.org/"
     xmlns:AnnotationVocabulary="https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/">
    <owl:Ontology rdf:about="https://w3id.org/mqto">
        <owl:versionIRI rdf:resource="https://w3id.org/mqto/1.0"/>
        <owl:imports rdf:resource="http://rds.posccaesar.org/ontology/lis14/ont/ido-ssn/0.1"/>
        <terms:abstract xml:lang="en">The Manufacturing Quality Troubleshooting Ontology (MQTO) provides a domain-independent semantic framework for modeling manufacturing quality inspection, failure diagnosis, and countermeasure recommendation. Building on the LIS (Lifecycle Information System) specified/actual pattern and integrating SOSA/SSN observation semantics, MQTO enables structured representation of Ishikawa (fishbone) root cause analysis across Machine, Material, and Method categories. The ontology supports both schema-level knowledge (failure types, metrics, countermeasure procedures) and instance-level data (actual observations, failure occurrences, executed remediation steps), making it applicable across diverse manufacturing domains including die-casting, injection molding, machining, and assembly processes.</terms:abstract>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-2661-5575"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-17</terms:created>
        <terms:creator rdf:resource="https://orcid.org/0000-0001-9521-8907"/>
        <terms:description xml:lang="en">A generalised ontology for manufacturing quality troubleshooting, applicable across different manufacturing domains. Covers both the specified (schema-level) and actual (instance-level) layers of a manufacturing process, with a focus on root cause analysis, failure diagnosis, and countermeasure recommendation.</terms:description>
        <terms:license rdf:resource="http://www.apache.org/licenses/LICENSE-2.0"/>
        <terms:publisher rdf:resource="https://github.com/dg-assist"/>
        <terms:rights xml:lang="en">Copyright 2026 DG Assist. Licensed under the Apache License, Version 2.0.</terms:rights>
        <terms:subject xml:lang="en">Industry 4.0</terms:subject>
        <terms:subject xml:lang="en">Ishikawa diagram</terms:subject>
        <terms:subject xml:lang="en">SOSA</terms:subject>
        <terms:subject xml:lang="en">SSN</terms:subject>
        <terms:subject xml:lang="en">die-casting</terms:subject>
        <terms:subject xml:lang="en">manufacturing</terms:subject>
        <terms:subject xml:lang="en">quality control</terms:subject>
        <terms:subject xml:lang="en">root cause analysis</terms:subject>
        <terms:subject xml:lang="en">troubleshooting</terms:subject>
        <terms:title xml:lang="en">Manufacturing Quality Troubleshooting Ontology</terms:title>
        <bibo:status rdf:resource="http://purl.org/ontology/bibo/status/draft"/>
        <vann:preferredNamespacePrefix>mqto</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>https://w3id.org/mqto#</vann:preferredNamespaceUri>
        <schema:codeRepository rdf:resource="https://github.com/dg-assist/mqto"/>
        <schema:funding rdf:resource="https://projekte.ffg.at/projekt/4641766"/>
        <schema:logo rdf:resource="https://dg-assist.github.io/mqto/logo.png"/>
        <rdfs:comment xml:lang="en">Relationship to Procedural Knowledge Ontology (PKO): mqto countermeasure classes align with PKO procedure modeling patterns. mqto:Countermeasure is a subclass of pko:Procedure, representing remediation procedures in the specified layer. mqto:CountermeasureStep aligns with p-plan:Step for individual actions. In the actual layer, mqto:CountermeasureExecution extends pko:ProcedureExecution and mqto:CountermeasureStepExecution extends pko:StepExecution. Both ontologies follow a specification/execution (plan/actual) pattern, though mqto uses LIS (lis:Specified/lis:Actual with lis:implements) while PKO uses P-PLAN/PROV (with pko:executesProcedure/pko:executesStep). Key architectural difference: mqto externalizes step ordering via mqto:List containers for step reusability across procedures, while PKO embeds ordering directly in steps via pko:nextStep properties.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/mqto/1.0"/>
        <rdfs:label xml:lang="en">Manufacturing Quality Troubleshooting Ontology</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://purl.org/net/p-plan"/>
        <rdfs:seeAlso rdf:resource="https://w3id.org/pko/1.0.0"/>
        <owl:versionInfo>1.0.0</owl:versionInfo>
        <foaf:homepage rdf:resource="https://dg-assist.github.io/mqto/"/>
    </owl:Ontology>
    


