<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/mqto#"
     xml:base="https://w3id.org/mqto"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:mod="https://w3id.org/mod#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:pav="http://purl.org/pav/"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:rdl="http://rds.posccaesar.org/ontology/lis14/rdl/"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:bibo="http://purl.org/ontology/bibo/"
     xmlns:dcam="http://purl.org/dc/dcam/"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:schema="http://schema.org/"
     xmlns:schema1="https://schema.org/"
     xmlns:AnnotationVocabulary="https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/">
    <owl:Ontology rdf:about="https://w3id.org/mqto">
        <owl:versionIRI rdf:resource="https://w3id.org/mqto/1.0"/>
        <owl:imports rdf:resource="http://rds.posccaesar.org/ontology/lis14/ont/ido-ssn/0.1"/>
        <owl:imports rdf:resource="https://w3id.org/pko/1.0.0"/>
        <terms:abstract xml:lang="en">The Manufacturing Quality Troubleshooting Ontology (MQTO) provides a domain-independent semantic framework for modeling manufacturing quality inspection, failure diagnosis, and countermeasure recommendation. Building on the LIS (Lifecycle Information System) specified/actual pattern and integrating SOSA/SSN observation semantics, MQTO enables structured representation of Ishikawa (fishbone) root cause analysis across five categories: Machine, Manpower, Material, Measurement, and Method. The ontology supports both schema-level knowledge (failure types, metrics, countermeasure procedures) and instance-level data (actual observations, failure occurrences, executed remediation steps), making it applicable across diverse manufacturing domains including die-casting, injection molding, machining, and assembly processes.</terms:abstract>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-3050-159X"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-2661-5575"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-3445-0504"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-17</terms:created>
        <terms:creator rdf:resource="https://orcid.org/0000-0001-9521-8907"/>
        <terms:description xml:lang="en">A connector ontology for manufacturing quality troubleshooting that bridges three manufacturing domains: quality management (FailureMode, Countermeasure, Metric), production context (FailureSourceCategory hierarchy, FailureSource hierarchy), and data infrastructure (Signal, Property, DataEvent). Applicable across manufacturing domains. Covers both the specified (schema-level) and actual (instance-level) levels, with a focus on root cause analysis, failure diagnosis, and countermeasure recommendation.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-27</terms:issued>
        <terms:license rdf:resource="http://www.apache.org/licenses/LICENSE-2.0"/>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-27</terms:modified>
        <terms:publisher rdf:resource="https://github.com/dg-assist"/>
        <terms:rights xml:lang="en">Copyright 2026 DG Assist. Licensed under the Apache License, Version 2.0.</terms:rights>
        <terms:subject xml:lang="en">Industry 4.0</terms:subject>
        <terms:subject xml:lang="en">Ishikawa diagram</terms:subject>
        <terms:subject xml:lang="en">SOSA</terms:subject>
        <terms:subject xml:lang="en">SSN</terms:subject>
        <terms:subject xml:lang="en">manufacturing</terms:subject>
        <terms:subject xml:lang="en">quality control</terms:subject>
        <terms:subject xml:lang="en">root cause analysis</terms:subject>
        <terms:subject xml:lang="en">troubleshooting</terms:subject>
        <terms:title xml:lang="en">Manufacturing Quality Troubleshooting Ontology</terms:title>
        <bibo:doi>10.5281/zenodo.19571023</bibo:doi>
        <bibo:status rdf:resource="http://purl.org/ontology/bibo/status/published"/>
        <vann:preferredNamespacePrefix>mqto</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>https://w3id.org/mqto#</vann:preferredNamespaceUri>
        <schema:codeRepository rdf:resource="https://github.com/dg-assist/mqto"/>
        <schema:funding rdf:resource="https://projekte.ffg.at/projekt/4641766"/>
        <schema:logo rdf:resource="https://dg-assist.github.io/mqto/logo.png"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/mqto/1.0"/>
        <rdfs:label xml:lang="en">Manufacturing Quality Troubleshooting Ontology</rdfs:label>
        <owl:versionInfo>1.0.0</owl:versionInfo>
        <skos:editorialNote xml:lang="en">PKO alignment: mqto:Countermeasure subclasses pko:Procedure, mqto:CountermeasureStep aligns with p-plan:Step, mqto:CountermeasureExecution extends pko:ProcedureExecution, and mqto:CountermeasureStepExecution extends pko:StepExecution. Both ontologies follow a specification/execution pattern, though MQTO uses LIS (lis:Specified/lis:Actual with lis:implements) while PKO uses P-PLAN/PROV. Key difference: MQTO externalizes step ordering via CountermeasureStepList containers for reusability, while PKO embeds ordering directly in steps via pko:nextStep.</skos:editorialNote>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/abstract -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/abstract"/>
    


    <!-- http://purl.org/dc/terms/subject -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/subject"/>
    


    <!-- http://purl.org/ontology/bibo/doi -->


    <owl:AnnotationProperty rdf:about="http://purl.org/ontology/bibo/doi"/>
    


    <!-- http://schema.org/codeRepository -->


    <owl:AnnotationProperty rdf:about="http://schema.org/codeRepository"/>
    


    <!-- http://schema.org/funding -->


    <owl:AnnotationProperty rdf:about="http://schema.org/funding"/>
    


    <!-- http://schema.org/logo -->


    <owl:AnnotationProperty rdf:about="http://schema.org/logo"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#editorialNote -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#editorialNote"/>
    


    <!-- https://schema.org/affiliation -->


    <owl:AnnotationProperty rdf:about="https://schema.org/affiliation"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#duration -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#duration"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://w3id.org/mqto#appearedOn -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#appearedOn">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#FailureOccurrence"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#FailureSource"/>
        <rdfs:comment xml:lang="en">Links a FailureOccurrence to the specific FailureSource where it manifested.</rdfs:comment>
        <rdfs:label xml:lang="en">appeared on</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#baseFor -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#baseFor">
        <owl:inverseOf rdf:resource="https://w3id.org/mqto#basedOn"/>
        <rdfs:domain rdf:resource="https://w3id.org/mqto#DataEvent"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#MetricAssessment"/>
        <rdfs:comment xml:lang="en">Indicates that an Observation or Actuation serves as the data foundation for a MetricAssessment calculation. Enables tracing from raw data to computed metrics.</rdfs:comment>
        <rdfs:label xml:lang="en">base for</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#basedOn -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#basedOn">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#MetricAssessment"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#DataEvent"/>
        <rdfs:comment xml:lang="en">Links a MetricAssessment to the Observation(s) or Actuation(s) used as input data for its calculation. Establishes the data provenance chain.</rdfs:comment>
        <rdfs:label xml:lang="en">based on</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#calculatedFor -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#calculatedFor">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#MetricAssessment"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#FailureSource"/>
        <rdfs:comment xml:lang="en">Links a MetricAssessment to the specific FailureSource it evaluates.</rdfs:comment>
        <rdfs:label xml:lang="en">calculated for</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#causedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#causedBy">
        <owl:inverseOf rdf:resource="https://w3id.org/mqto#causes"/>
        <rdfs:domain rdf:resource="https://w3id.org/mqto#FailureMode"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#FailureMode"/>
        <rdfs:comment xml:lang="en">Links a Failure Mode to another Failure Mode that causes it, forming a causal chain. Three sub-properties (causedByWeakly, causedByModerately, causedByStrongly) express different causal strengths.</rdfs:comment>
        <rdfs:label xml:lang="en">caused by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#causedByModerately -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#causedByModerately">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/mqto#causedBy"/>
        <owl:inverseOf rdf:resource="https://w3id.org/mqto#causesModerately"/>
        <rdfs:comment xml:lang="en">Indicates a moderate-strength causal relationship where one Failure Mode is caused by another with medium probability or influence. Enables ordinal ranking of causal strengths without requiring precise numeric probabilities. Subproperty of causedBy.</rdfs:comment>
        <rdfs:label xml:lang="en">caused by moderately</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#causedByStrongly -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#causedByStrongly">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/mqto#causedBy"/>
        <owl:inverseOf rdf:resource="https://w3id.org/mqto#causesStrongly"/>
        <rdfs:comment xml:lang="en">Indicates a strong causal relationship where one Failure Mode is caused by another with high probability or significant influence. Enables ordinal ranking of causal strengths without requiring precise numeric probabilities. Subproperty of causedBy.</rdfs:comment>
        <rdfs:label xml:lang="en">caused by strongly</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#causedByWeakly -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#causedByWeakly">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/mqto#causedBy"/>
        <owl:inverseOf rdf:resource="https://w3id.org/mqto#causesWeakly"/>
        <rdfs:comment xml:lang="en">Indicates a weak causal relationship where one Failure Mode is caused by another with low probability or minor influence. Enables ordinal ranking of causal strengths without requiring precise numeric probabilities. Subproperty of causedBy.</rdfs:comment>
        <rdfs:label xml:lang="en">caused by weakly</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#causes -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#causes">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#FailureMode"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#FailureMode"/>
        <rdfs:comment xml:lang="en">Links a Failure Mode to another Failure Mode that it causes, forming a causal chain. Three sub-properties (causesWeakly, causesModerately, causesStrongly) express different causal strengths.</rdfs:comment>
        <rdfs:label xml:lang="en">causes</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#causesModerately -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#causesModerately">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/mqto#causes"/>
        <rdfs:comment xml:lang="en">Indicates a moderate-strength causal relationship where one Failure Mode causes another with medium probability or influence. Enables ordinal ranking of causal strengths without requiring precise numeric probabilities. Subproperty of causes.</rdfs:comment>
        <rdfs:label xml:lang="en">causes moderately</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#causesStrongly -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#causesStrongly">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/mqto#causes"/>
        <rdfs:comment xml:lang="en">Indicates a strong causal relationship where one Failure Mode causes another with high probability or significant influence. Enables ordinal ranking of causal strengths without requiring precise numeric probabilities. Subproperty of causes.</rdfs:comment>
        <rdfs:label xml:lang="en">causes strongly</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#causesWeakly -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#causesWeakly">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/mqto#causes"/>
        <rdfs:comment xml:lang="en">Indicates a weak causal relationship where one Failure Mode causes another with low probability or minor influence. Enables ordinal ranking of causal strengths without requiring precise numeric probabilities. Subproperty of causes.</rdfs:comment>
        <rdfs:label xml:lang="en">causes weakly</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#evaluatedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#evaluatedBy">
        <owl:inverseOf rdf:resource="https://w3id.org/mqto#evaluatesProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Property"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#MetricAssessment"/>
        <rdfs:comment xml:lang="en">Relates a Property to the MetricAssessment that evaluated it (actual level). Counterpart to readBy in the specified level.</rdfs:comment>
        <rdfs:label xml:lang="en">evaluated by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#evaluatesProperty -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#evaluatesProperty">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#MetricAssessment"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#Property"/>
        <rdfs:comment xml:lang="en">Relates a MetricAssessment to the Property it evaluated (actual level). Counterpart to readsFrom in the specified level.</rdfs:comment>
        <rdfs:label xml:lang="en">evaluates property</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#failureBelongsTo -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#failureBelongsTo">
        <owl:inverseOf rdf:resource="https://w3id.org/mqto#hasFailure"/>
        <rdfs:domain rdf:resource="https://w3id.org/mqto#FailureMode"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#FailureSourceCategory"/>
        <rdfs:comment xml:lang="en">Associates a Failure Mode with the FailureSourceCategory it belongs to. Establishes which root cause category the failure is classified under.</rdfs:comment>
        <rdfs:label xml:lang="en">failure belongs to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#first -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#first">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#CountermeasureStepList"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#CountermeasureStep"/>
        <rdfs:comment xml:lang="en">Points to the first CountermeasureStep in an ordered list.</rdfs:comment>
        <rdfs:label xml:lang="en">first</rdfs:label>
        <skos:editorialNote xml:lang="en">The list structure enables step reuse across Countermeasure procedures without embedding order into steps.</skos:editorialNote>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#hasFailure -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#hasFailure">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#FailureSourceCategory"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#FailureMode"/>
        <rdfs:comment xml:lang="en">Associates a FailureSourceCategory with a Failure Mode that can occur in that category. Establishes which failures belong to each root cause category.</rdfs:comment>
        <rdfs:label xml:lang="en">has failure</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#hasMetric -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#hasMetric">
        <owl:inverseOf rdf:resource="https://w3id.org/mqto#metricBelongsTo"/>
        <rdfs:domain rdf:resource="https://w3id.org/mqto#FailureSourceCategory"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#Metric"/>
        <rdfs:comment xml:lang="en">Associates a FailureSourceCategory with a Metric used to monitor or assess that category. Establishes which metrics are relevant for each root cause category.</rdfs:comment>
        <rdfs:label xml:lang="en">has metric</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#hasStepList -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#hasStepList">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Countermeasure"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#CountermeasureStepList"/>
        <rdfs:comment xml:lang="en">Links a Countermeasure to its ordered step container.</rdfs:comment>
        <rdfs:label xml:lang="en">has step list</rdfs:label>
        <skos:editorialNote xml:lang="en">Named hasStepList rather than hasStep to distinguish from pko:hasStep, which links directly to step instances rather than to a list container.</skos:editorialNote>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#metricBelongsTo -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#metricBelongsTo">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Metric"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#FailureSourceCategory"/>
        <rdfs:comment xml:lang="en">Associates a Metric with the FailureSourceCategory it monitors or assesses. Establishes which root cause category a metric is used for.</rdfs:comment>
        <rdfs:label xml:lang="en">metric belongs to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#metricReferredBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#metricReferredBy">
        <owl:inverseOf rdf:resource="https://w3id.org/mqto#refersToMetric"/>
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Metric"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#FailureMode"/>
        <rdfs:comment xml:lang="en">Indicates that a Metric is referred to by a Failure Mode for diagnostic purposes. Establishes which failures use which metrics for detection.</rdfs:comment>
        <rdfs:label xml:lang="en">metric referred by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#mitigatedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#mitigatedBy">
        <owl:inverseOf rdf:resource="https://w3id.org/mqto#mitigates"/>
        <rdfs:domain rdf:resource="https://w3id.org/mqto#FailureMode"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#Countermeasure"/>
        <rdfs:comment xml:lang="en">Links a Failure Mode to a Countermeasure that can remediate or reduce it (specified level). Actual-level counterparts: mitigatedOccurrence and mitigatedByExecution.</rdfs:comment>
        <rdfs:label xml:lang="en">mitigated by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#mitigatedByExecution -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#mitigatedByExecution">
        <owl:inverseOf rdf:resource="https://w3id.org/mqto#mitigatedOccurrence"/>
        <rdfs:domain rdf:resource="https://w3id.org/mqto#FailureOccurrence"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#CountermeasureExecution"/>
        <rdfs:comment xml:lang="en">Links a FailureOccurrence to the CountermeasureExecution that addressed it (actual level). Specified-level counterpart: mitigatedBy.</rdfs:comment>
        <rdfs:label xml:lang="en">mitigated by execution</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#mitigatedOccurrence -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#mitigatedOccurrence">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#CountermeasureExecution"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#FailureOccurrence"/>
        <rdfs:comment xml:lang="en">Links a CountermeasureExecution to the FailureOccurrence it addressed (actual level). Specified-level counterpart: mitigates.</rdfs:comment>
        <rdfs:label xml:lang="en">mitigated occurrence</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#mitigates -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#mitigates">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Countermeasure"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#FailureMode"/>
        <rdfs:comment xml:lang="en">Links a Countermeasure to the Failure Mode(s) it can remediate or reduce (specified level). Actual-level counterparts: mitigatedOccurrence and mitigatedByExecution.</rdfs:comment>
        <rdfs:label xml:lang="en">mitigates</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#providesSignal -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#providesSignal">
        <owl:inverseOf rdf:resource="https://w3id.org/mqto#signalProvidedBy"/>
        <rdfs:domain rdf:resource="https://w3id.org/mqto#FailureSourceCategory"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#Signal"/>
        <rdfs:comment xml:lang="en">Relates a FailureSourceCategory to the data channels (Signals) associated with it.</rdfs:comment>
        <rdfs:label xml:lang="en">provides signal</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#raised -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#raised">
        <owl:inverseOf rdf:resource="https://w3id.org/mqto#raisedBy"/>
        <rdfs:domain rdf:resource="https://w3id.org/mqto#MetricAssessment"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#FailureOccurrence"/>
        <rdfs:comment xml:lang="en">Links a MetricAssessment to the FailureOccurrence it detected or triggered. Establishes which failures were raised by threshold violations.</rdfs:comment>
        <rdfs:label xml:lang="en">raised</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#raisedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#raisedBy">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#FailureOccurrence"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#MetricAssessment"/>
        <rdfs:comment xml:lang="en">Links a FailureOccurrence to the MetricAssessment(s) that detected or triggered it. Establishes which metric evaluations identified the failure.</rdfs:comment>
        <rdfs:label xml:lang="en">raised by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#readBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#readBy">
        <owl:inverseOf rdf:resource="https://w3id.org/mqto#readsFrom"/>
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Signal"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#Metric"/>
        <rdfs:comment xml:lang="en">Relates a Signal to the Metric that is computed from it (specified level). For the actual-level counterpart see evaluatedBy.</rdfs:comment>
        <rdfs:label xml:lang="en">read by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#readsFrom -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#readsFrom">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Metric"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#Signal"/>
        <rdfs:comment xml:lang="en">Relates a Metric to the Signal it is computed from (specified level). For the actual-level counterpart see evaluatesProperty.</rdfs:comment>
        <rdfs:label xml:lang="en">reads from</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#refersToMetric -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#refersToMetric">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#FailureMode"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#Metric"/>
        <rdfs:comment xml:lang="en">Links a Failure Mode to the Metric(s) used for its detection or characterization. Establishes which quantitative assessments are diagnostic indicators.</rdfs:comment>
        <rdfs:label xml:lang="en">refers to metric</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#rest -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#rest">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#CountermeasureStepList"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#CountermeasureStepList"/>
        <rdfs:comment xml:lang="en">Points to the remainder of the ordered step list. Together with mqto:first, implements a linked-list pattern terminated at mqto:nil.</rdfs:comment>
        <rdfs:label xml:lang="en">rest</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#resultProperty -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#resultProperty">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Metric"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
        <rdfs:comment xml:lang="en">Specifies which data property of mqto:Result instances a Metric reads to obtain its input value. Each Metric selects exactly one property from Result instances that may carry multiple measured values.</rdfs:comment>
        <rdfs:label xml:lang="en">result property</rdfs:label>
        <skos:editorialNote xml:lang="en">Meta-level construct: an object property whose value is itself a property. Falls outside normal OWL type-system validation but provides a simple, declarative way to parameterise Metrics without requiring SPARQL property-path strings or SHACL infrastructure.</skos:editorialNote>
        <skos:example xml:lang="en">A PLC cycle produces one Result with three data properties:
  ex:Result_Shot042  ex:temperature  718.3 ;
                     ex:pressure     980.0 ;
                     ex:cycleTime     24.7 .

Two Metrics select different properties from the same Result:
  ex:TemperatureMetric  mqto:resultProperty  ex:temperature .
  ex:PressureMetric     mqto:resultProperty  ex:pressure .

At query time: SELECT ?value WHERE { ?metric mqto:resultProperty ?prop . ?result ?prop ?value . }</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#signalProvidedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#signalProvidedBy">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Signal"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#FailureSourceCategory"/>
        <rdfs:comment xml:lang="en">Associates a Signal with the FailureSourceCategory that provides it. Establishes the source of measurement or control data channels.</rdfs:comment>
        <rdfs:label xml:lang="en">signal provided by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#suggested -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#suggested">
        <owl:inverseOf rdf:resource="https://w3id.org/mqto#suggestedBy"/>
        <rdfs:domain rdf:resource="https://w3id.org/mqto#FailureOccurrence"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#CountermeasureExecution"/>
        <rdfs:comment xml:lang="en">Links a FailureOccurrence to a CountermeasureExecution that was recommended in response. Distinct from mitigatedOccurrence (which records actual resolution).</rdfs:comment>
        <rdfs:label xml:lang="en">suggested</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mqto#suggestedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mqto#suggestedBy">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#CountermeasureExecution"/>
        <rdfs:range rdf:resource="https://w3id.org/mqto#FailureOccurrence"/>
        <rdfs:comment xml:lang="en">Links a CountermeasureExecution to the FailureOccurrence that triggered its recommendation. Distinct from mitigatedByExecution (which records actual resolution).</rdfs:comment>
        <rdfs:label xml:lang="en">suggested by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pko#includesStepExecution -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pko#includesStepExecution"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://w3id.org/mqto#abortedReason -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#abortedReason">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Human-readable explanation of why a CountermeasureStepExecution or CountermeasureExecution was aborted before completion.</rdfs:comment>
        <rdfs:label xml:lang="en">aborted reason</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#abortedTime -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#abortedTime">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">The timestamp when a CountermeasureStepExecution or CountermeasureExecution was aborted before normal completion.</rdfs:comment>
        <rdfs:label xml:lang="en">aborted time</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#assessmentMethod -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#assessmentMethod">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Metric"/>
        <rdfs:comment xml:lang="en">The calculation method applied by a Metric to compute its value from observations. Describes the algorithm or statistical function used to aggregate data.</rdfs:comment>
        <rdfs:label xml:lang="en">assessment method</rdfs:label>
        <skos:example xml:lang="en">average, maximum, standard deviation, trend slope</skos:example>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#assessmentValue -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#assessmentValue">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#MetricAssessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Boolean pass/fail decision from threshold comparison. True indicates a threshold violation (failure detected), false indicates normal operation within bounds.</rdfs:comment>
        <rdfs:label xml:lang="en">assessment value</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#calculatedTime -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#calculatedTime">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#MetricAssessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">The timestamp when a MetricAssessment was computed. Marks the moment the metric calculation and threshold comparison were evaluated.</rdfs:comment>
        <rdfs:label xml:lang="en">calculated time</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#calculatedValue -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#calculatedValue">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#MetricAssessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">The computed numeric value of a MetricAssessment, preserving the quantitative result before threshold comparison.</rdfs:comment>
        <rdfs:label xml:lang="en">calculated value</rdfs:label>
        <skos:editorialNote xml:lang="en">Unit of measurement is inherited from the implemented Metric specification.</skos:editorialNote>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#completionTime -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#completionTime">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#CountermeasureStepExecution"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">The timestamp when a CountermeasureStepExecution was successfully completed. If a step is aborted, use abortedTime instead.</rdfs:comment>
        <rdfs:label xml:lang="en">completion time</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#endTime -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#endTime">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">The timestamp when an activity or time-bound entity concluded. General-purpose temporal property applicable to execution contexts.</rdfs:comment>
        <rdfs:label xml:lang="en">end time</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#identifier -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#identifier">
        <rdfs:comment xml:lang="en">A unique identifier for an entity. Enables correlation between ontology instances and external systems.</rdfs:comment>
        <rdfs:label xml:lang="en">identifier</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://purl.org/dc/terms/identifier"/>
        <skos:editorialNote xml:lang="en">Conceptually aligned with dcterms:identifier but declared independently because OWL 2 DL does not permit a datatype property to be a subproperty of an annotation property.</skos:editorialNote>
        <skos:example xml:lang="en">machine serial number, material batch code, signal name, process ID</skos:example>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#itemWindowSize -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#itemWindowSize">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Metric"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">The number of production items over which a Metric aggregates observations. Complements timeWindowSize for item-count-based windows.</rdfs:comment>
        <rdfs:label xml:lang="en">item window size</rdfs:label>
        <skos:example xml:lang="en">last 10 shots, last 5 batches</skos:example>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#lowerBound -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#lowerBound">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Metric"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">The minimum acceptable threshold value for a Metric. Values below the lowerBound indicate a threshold violation.</rdfs:comment>
        <rdfs:label xml:lang="en">lower bound</rdfs:label>
        <skos:editorialNote xml:lang="en">Stored as dimensionless xsd:double; unit of measurement determined by the Metric&apos;s associated Signal.</skos:editorialNote>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#occurrenceTime -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#occurrenceTime">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#FailureOccurrence"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">The timestamp when this failure occurrence actually happened in the physical world. Essential for failure frequency analysis and temporal correlation.</rdfs:comment>
        <rdfs:label xml:lang="en">occurrence time</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#score -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#score">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#CountermeasureExecution"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">A numeric score or confidence value assigned to a CountermeasureExecution recommendation. Used by diagnostic systems to rank countermeasure suggestions.</rdfs:comment>
        <rdfs:label xml:lang="en">score</rdfs:label>
        <skos:editorialNote xml:lang="en">The interpretation and scale of scores is application-specific.</skos:editorialNote>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#startTime -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#startTime">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">The timestamp when an activity or time-bound entity began. General-purpose temporal property applicable to execution contexts.</rdfs:comment>
        <rdfs:label xml:lang="en">start time</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#timeWindowSize -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#timeWindowSize">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Metric"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#duration"/>
        <rdfs:comment xml:lang="en">The duration over which a Metric aggregates observations, expressed as xsd:duration. Defines how far back in time to consider observation data.</rdfs:comment>
        <rdfs:label xml:lang="en">time window size</rdfs:label>
        <skos:example xml:lang="en">PT5M (5 minutes), PT1H (1 hour)</skos:example>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#upperBound -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#upperBound">
        <rdfs:domain rdf:resource="https://w3id.org/mqto#Metric"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">The maximum acceptable threshold value for a Metric. Values above the upperBound indicate a threshold violation.</rdfs:comment>
        <rdfs:label xml:lang="en">upper bound</rdfs:label>
        <skos:editorialNote xml:lang="en">Stored as dimensionless xsd:double; unit of measurement determined by the Metric&apos;s associated Signal.</skos:editorialNote>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mqto#weight -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mqto#weight">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/mqto#Countermeasure"/>
                    <rdf:Description rdf:about="https://w3id.org/mqto#FailureMode"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:comment xml:lang="en">A relative ranking weight. For Failure Modes: severity or priority. For Countermeasures: effectiveness or preference. Provides anchor points for external ranking logic.</rdfs:comment>
        <rdfs:label xml:lang="en">weight</rdfs:label>
        <skos:editorialNote xml:lang="en">The ontology does not prescribe the ranking algorithm itself; interpretation is application-specific.</skos:editorialNote>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/1999/02/22-rdf-syntax-ns#Property -->


    <owl:Class rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    


    <!-- http://www.w3.org/ns/sosa/ActuableProperty -->


    <owl:Class rdf:about="http://www.w3.org/ns/sosa/ActuableProperty"/>
    


    <!-- https://w3id.org/mqto#ActuableProperty -->


    <owl:Class rdf:about="https://w3id.org/mqto#ActuableProperty">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/ActuableProperty"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/mqto#Property"/>
        <rdfs:comment xml:lang="en">An actuable property of a FailureSource that can be controlled or modified via Actuations. Implements a Signal specification.</rdfs:comment>
        <rdfs:label xml:lang="en">Actuable Property</rdfs:label>
        <skos:example xml:lang="en">setpoints, valve positions, motor speeds, control commands</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#Actuation -->


    <owl:Class rdf:about="https://w3id.org/mqto#Actuation">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Actuation"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/mqto#DataEvent"/>
        <rdfs:comment xml:lang="en">A single actuation event that changes the state of an ActuableProperty. As a DataEvent, can serve as the basis for MetricAssessments.</rdfs:comment>
        <rdfs:label xml:lang="en">Actuation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#Countermeasure -->


    <owl:Class rdf:about="https://w3id.org/mqto#Countermeasure">
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/Activity"/>
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/Specified"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pko#Procedure"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#hasStepList"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/mqto#CountermeasureStepList"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/hasParticipant"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/mqto#Machine"/>
                            <rdf:Description rdf:about="https://w3id.org/mqto#Manpower"/>
                            <rdf:Description rdf:about="https://w3id.org/mqto#Material"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#mitigates"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#FailureMode"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A remediation procedure that mitigates one or more Failure Modes. Structured as an ordered sequence of CountermeasureSteps.</rdfs:comment>
        <rdfs:label xml:lang="en">Countermeasure</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#CountermeasureExecution -->


    <owl:Class rdf:about="https://w3id.org/mqto#CountermeasureExecution">
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/Activity"/>
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/Actual"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pko#ProcedureExecution"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/implements"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/mqto#Countermeasure"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#mitigatedOccurrence"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#FailureOccurrence"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#suggestedBy"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#FailureOccurrence"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pko#includesStepExecution"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#CountermeasureStepExecution"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">The actual execution of a Countermeasure procedure, performed to mitigate one or more FailureOccurrences. Step sequencing uses pko:nextStepExecution/pko:previousStepExecution.</rdfs:comment>
        <rdfs:label xml:lang="en">Countermeasure Execution</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#CountermeasureStep -->


    <owl:Class rdf:about="https://w3id.org/mqto#CountermeasureStep">
        <rdfs:subClassOf rdf:resource="http://purl.org/net/p-plan#Step"/>
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/Activity"/>
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/Specified"/>
        <rdfs:comment xml:lang="en">A reusable specification of a single remediation step.</rdfs:comment>
        <rdfs:label xml:lang="en">Countermeasure Step</rdfs:label>
        <skos:editorialNote xml:lang="en">Ordering is externalized to CountermeasureStepList containers, enabling the same step to appear in multiple Countermeasure procedures.</skos:editorialNote>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#CountermeasureStepExecution -->


    <owl:Class rdf:about="https://w3id.org/mqto#CountermeasureStepExecution">
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/Activity"/>
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/Actual"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pko#StepExecution"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/implements"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/mqto#CountermeasureStep"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">The actual execution of one CountermeasureStep. Step sequencing uses pko:nextStepExecution and pko:previousStepExecution.</rdfs:comment>
        <rdfs:label xml:lang="en">Countermeasure Step Execution</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#CountermeasureStepList -->


    <owl:Class rdf:about="https://w3id.org/mqto#CountermeasureStepList">
        <rdfs:comment xml:lang="en">An ordered, reusable container of CountermeasureSteps. Uses an OWL-native linked list pattern (mqto:first / mqto:rest), terminated by mqto:nil.</rdfs:comment>
        <rdfs:label xml:lang="en">Countermeasure Step List</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://www.w3.org/TR/owl2-primer/"/>
        <skos:editorialNote xml:lang="en">Uses explicit OWL class and property definitions instead of rdf:List for reasoner compatibility. Standard rdf:List creates known issues with OWL reasoners due to blank node handling and recursive structure reasoning. See OWL 2 Primer Section 4.2.</skos:editorialNote>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#DataEvent -->


    <owl:Class rdf:about="https://w3id.org/mqto#DataEvent">
        <rdfs:comment xml:lang="en">Common superclass of mqto:Observation and mqto:Actuation. Allows MetricAssessments to be grounded in either sensor observations or actuation events.</rdfs:comment>
        <rdfs:label xml:lang="en">Data Event</rdfs:label>
        <skos:editorialNote xml:lang="en">Mirrors the mqto:Property pattern which bridges ObservableProperty and ActuableProperty at the actual level.</skos:editorialNote>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#FailureMode -->


    <owl:Class rdf:about="https://w3id.org/mqto#FailureMode">
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/Specified"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#failureBelongsTo"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/mqto#FailureSourceCategory"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#causedBy"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#FailureMode"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#causes"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#FailureMode"/>
            </owl:Restriction>
