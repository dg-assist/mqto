            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Raw materials, consumables, and inputs to manufacturing. Represents specified material types that participate in Methods.</rdfs:comment>
        <rdfs:label xml:lang="en">Material</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#Measurement -->


