    </owl:Class>
    


    <!-- https://w3id.org/mqto#Metric -->


    <owl:Class rdf:about="https://w3id.org/mqto#Metric">
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/Specified"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#metricBelongsTo"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/mqto#FailureSourceCategory"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#metricReferredBy"/>
