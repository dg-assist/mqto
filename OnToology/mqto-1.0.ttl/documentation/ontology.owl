            <owl:Restriction>
                <owl:onProperty rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/implements"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/mqto#FailureMode"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mqto#appearedOn"/>
