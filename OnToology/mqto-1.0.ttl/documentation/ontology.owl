            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A manner in which a manufacturing component, system, or process could potentially fail (per IEC 60812:2018). Supports causal chains and countermeasure mitigation. Actual-level counterpart: FailureOccurrence.</rdfs:comment>
        <rdfs:label xml:lang="en">Failure Mode</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#FailureOccurrence -->


    <owl:Class rdf:about="https://w3id.org/mqto#FailureOccurrence">
