        <rdfs:comment xml:lang="en">A measurement procedure or inspection method. Specifies how a quantity is measured or a quality attribute is assessed.</rdfs:comment>
        <rdfs:label xml:lang="en">Measurement</rdfs:label>
        <skos:editorialNote xml:lang="en">Actual-level counterpart expressed via sosa:Observation instances referencing this procedure through sosa:usedProcedure.</skos:editorialNote>
        <skos:editorialNote xml:lang="en">As a subclass of sosa:Procedure (lis:InformationObject in ido-ssn), Measurement is an information object rather than a physical thing or activity.</skos:editorialNote>
    </owl:Class>
    


    <!-- https://w3id.org/mqto#Method -->


    <owl:Class rdf:about="https://w3id.org/mqto#Method">
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/Activity"/>
