# CQ-13: Was a suggested countermeasure or step execution aborted?
#
# This query identifies countermeasure executions and step executions that were
# aborted before completion, indicating inapplicable or unsuccessful remediation
# attempts. Uses mqto:abortedTime and mqto:abortedReason to detect and explain aborts.

PREFIX mqto: <https://w3id.org/mqto#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX lis: <http://rds.posccaesar.org/ontology/lis14/rdl/>

SELECT ?item ?itemType ?itemLabel ?abortedTime ?abortedReason
WHERE {
  {
    # Aborted countermeasure executions
    ?item a mqto:CountermeasureExecution ;
          mqto:abortedTime ?abortedTime .

    BIND("CountermeasureExecution" AS ?itemType)

    OPTIONAL {
      ?item lis:implements ?cmSpec .
      ?cmSpec rdfs:label ?itemLabel .
    }

    OPTIONAL { ?item mqto:abortedReason ?abortedReason . }
  }
  UNION
  {
    # Aborted countermeasure step executions
    ?item a mqto:CountermeasureStepExecution ;
          mqto:abortedTime ?abortedTime .

    BIND("CountermeasureStepExecution" AS ?itemType)

    OPTIONAL {
      ?item lis:implements ?stepSpec .
      ?stepSpec rdfs:label ?itemLabel .
    }

    OPTIONAL { ?item mqto:abortedReason ?abortedReason . }
  }
}
ORDER BY DESC(?abortedTime)
